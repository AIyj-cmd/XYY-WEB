{
  "name": "xyy-website",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "start": "node server.mjs",
    "typecheck": "astro check",
    "lint": "eslint .",
    "format": "prettier --write astro.config.mjs server.mjs ecosystem.config.cjs eslint.config.mjs vitest.config.ts playwright.config.ts lighthouserc.cjs \"scripts/*.{mjs,json}\" \"src/lib/**/*.{ts,css}\" src/pages/api/contact.ts \"tests/**/*.ts\"",
    "format:check": "prettier --check astro.config.mjs server.mjs ecosystem.config.cjs eslint.config.mjs vitest.config.ts playwright.config.ts lighthouserc.cjs \"scripts/*.{mjs,json}\" \"src/lib/**/*.{ts,css}\" src/pages/api/contact.ts \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:lhci": "lhci autorun",
    "audit": "npm audit --omit=dev",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=9.6.5"
  },
  "dependencies": {
    "@astrojs/node": "^11.0.2",
    "@astrojs/sitemap": "^3.7.3",
    "@directus/sdk": "^23.0.0",
    "astro": "^7.0.6",
    "compression": "^1.8.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "gsap": "^3.15.0",
    "lenis": "^1.3.25",
    "sanitize-html": "^2.17.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@fontpkg/alibaba-puhuiti-3-0": "^0.0.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.0",
    "@types/sanitize-html": "^2.16.1",
    "cn-font-split": "^7.4.3",
    "eslint": "^10.6.0",
    "eslint-plugin-astro": "^2.1.1",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "cn-font-split@7.4.3": true,
    "esbuild@0.28.1": true,
    "koffi@2.10.0": true,
    "protobufjs@7.6.5": true
  }
}
