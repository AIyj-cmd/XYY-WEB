---
import { NAV_LINKS } from '@/lib/brand'
const pathname = Astro.url.pathname

const SPECIALTY_LINKS = [
  { href: '/xiefu-yuncang', label: '鞋服云仓', sub: 'B2C+B2B+O2O全渠道' },
  { href: '/fuzhuang-yuncang', label: '服装云仓', sub: '全品类鞋服仓储' },
  { href: '/tuihuo-zhijian', label: '退货质检', sub: 'AQL 1.0–6.5标准' },
  { href: '/houzheng-xiufu', label: '后整修复', sub: '修复成功率90%+' },
  { href: '/kuajing-yuncang', label: '跨境云仓', sub: '跨境退货+国际质检' },
  { href: '/zhibo-cangpei', label: '直播电商仓配', sub: '抖音/快手/淘宝直播' },
  { href: '/huanan-xiefu-yuncang', label: '华南鞋服云仓', sub: '广州+东莞+肇庆' },
  { href: '/guangzhou-xiefu-yuncang', label: '广州鞋服云仓', sub: '黄埔+番禺双仓' },
]

const isProductActive = pathname === '/product' || SPECIALTY_LINKS.some(l => pathname.startsWith(l.href))
---

<header
  class="fixed top-0 left-0 right-0 z-50 border-b border-white/10"
  style="background: rgba(8,20,42,0.92); -webkit-backdrop-filter: blur(8px); backdrop-filter: blur(8px);"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" aria-label="新亦源供应链首页" class="hover:opacity-85 transition-opacity">
        <img
          src="/logo.png"
          alt="新亦源供应链"
          height="36"
          class="h-9 w-auto object-contain"
          fetchpriority="high"
        />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="主导航">
        {NAV_LINKS.map(({ href, label }) => {
          if (href === '/product') {
            return (
              <div class="relative group">
                <a
                  href="/product"
                  class:list={[
                    'flex items-center gap-1 px-3 py-2 rounded-md text-sm font-medium transition-colors',
                    isProductActive
                      ? 'bg-white/15 text-white'
                      : 'text-navy-100 hover:bg-white/10 hover:text-white',
                  ]}
                  aria-current={isProductActive ? 'page' : undefined}
                  aria-haspopup="true"
                >
                  {label}
                  <svg class="w-3.5 h-3.5 opacity-60 group-hover:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
                  </svg>
                </a>
                <!-- Dropdown panel -->
                <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto transition-opacity duration-150 z-50">
                  <!-- invisible bridge to prevent hover gap -->
                  <div class="absolute -top-2 left-0 right-0 h-2"></div>
                  <div class="w-72 rounded-xl border border-white/10 shadow-2xl overflow-hidden"
                    style="background: rgba(8,20,42,0.97); backdrop-filter: blur(12px);">
                    <div class="p-3 grid grid-cols-2 gap-1">
                      {SPECIALTY_LINKS.map(({ href: sh, label: sl, sub }) => {
                        const isSpActive = pathname.startsWith(sh)
                        return (
                          <a
                            href={sh}
                            class:list={[
                              'flex flex-col gap-0.5 px-3 py-2.5 rounded-lg transition-colors',
                              isSpActive
                                ? 'bg-white/15 text-white'
                                : 'text-navy-100 hover:bg-white/10 hover:text-white',
                            ]}
                          >
                            <span class="text-xs font-bold leading-tight">{sl}</span>
                            <span class="text-[10px] opacity-55 leading-tight">{sub}</span>
                          </a>
                        )
                      })}
                    </div>
                    <div class="border-t border-white/10 px-3 py-2">
                      <a href="/product" class="flex items-center justify-center gap-1 text-[11px] text-navy-300 hover:text-white transition-colors py-1">
                        查看全部产品服务
                        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                        </svg>
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            )
          }
          const isActive = href === '/' ? pathname === '/' : pathname.startsWith(href)
          return (
            <a
              href={href}
              class:list={[
                'px-3 py-2 rounded-md text-sm font-medium transition-colors',
                isActive
                  ? 'bg-white/15 text-white'
                  : 'text-navy-100 hover:bg-white/10 hover:text-white',
              ]}
              aria-current={isActive ? 'page' : undefined}
            >
              {label}
            </a>
          )
        })}
      </nav>

      <!-- CTA + Mobile toggle -->
      <div class="flex items-center gap-3">
        <a
          href="/contact"
          class="hidden sm:inline-flex items-center px-4 py-2 bg-brand-orange hover:bg-brand-orange-dark text-white text-sm font-semibold rounded-lg transition-colors"
        >
          免费咨询
        </a>
        <button
          id="mobile-menu-btn"
          type="button"
          class="lg:hidden text-white p-2 rounded-md hover:bg-white/10 transition-colors"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="打开菜单"
        >
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-white/10 bg-navy-900" role="navigation" aria-label="移动端导航">
    <div class="px-4 py-3 space-y-1">
      {NAV_LINKS.map(({ href, label }) => {
        if (href === '/product') {
          return (
            <div>
              <a
                href="/product"
                class:list={[
                  'block px-3 py-2 rounded-md text-sm font-medium transition-colors',
                  isProductActive ? 'bg-white/15 text-white' : 'text-navy-100 hover:bg-white/10 hover:text-white',
                ]}
              >
                {label}
              </a>
              <div class="ml-4 mt-1 grid grid-cols-2 gap-1">
                {SPECIALTY_LINKS.map(({ href: sh, label: sl }) => {
                  const isSpActive = pathname.startsWith(sh)
                  return (
                    <a
                      href={sh}
                      class:list={[
                        'px-3 py-1.5 rounded-md text-xs font-medium transition-colors',
                        isSpActive ? 'bg-white/15 text-white' : 'text-navy-300 hover:bg-white/10 hover:text-white',
                      ]}
                    >
                      {sl}
                    </a>
                  )
                })}
              </div>
            </div>
          )
        }
        const isActive = href === '/' ? pathname === '/' : pathname.startsWith(href)
        return (
          <a
            href={href}
            class:list={[
              'block px-3 py-2 rounded-md text-sm font-medium transition-colors',
              isActive ? 'bg-white/15 text-white' : 'text-navy-100 hover:bg-white/10 hover:text-white',
            ]}
          >
            {label}
          </a>
        )
      })}
      <div class="pt-2 border-t border-white/10">
        <a
          href="/contact"
          class="block w-full text-center px-4 py-2.5 bg-brand-orange text-white text-sm font-semibold rounded-lg hover:bg-brand-orange-dark transition-colors"
        >
          免费咨询
        </a>
      </div>
    </div>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-16" aria-hidden="true"></div>

<script>
  const btn = document.getElementById('mobile-menu-btn')
  const menu = document.getElementById('mobile-menu')
  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden')
    menu?.classList.toggle('hidden', isOpen)
    btn.setAttribute('aria-expanded', String(!isOpen))
    btn.setAttribute('aria-label', isOpen ? '打开菜单' : '关闭菜单')
  })
</script>
