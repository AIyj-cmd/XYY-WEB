---
interface FaqItem { q: string; a: string }
interface Props {
  heading?: string
  tag?: string
  items: FaqItem[]
}
const { heading = '常见问题', tag = 'FAQ', items } = Astro.props
---

<section class="py-16 bg-white" aria-labelledby="page-faq-heading">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-10">
      <p class="text-brand-orange font-bold text-[11px] tracking-[0.35em] uppercase mb-2">{tag}</p>
      <h2 id="page-faq-heading" class="text-3xl font-black text-navy-800">{heading}</h2>
    </div>
    <dl class="divide-y divide-gray-100 border-t border-gray-100">
      {items.map(({ q, a }) => (
        <details class="group py-5">
          <summary class="flex items-start justify-between gap-4 cursor-pointer list-none">
            <dt class="text-base font-bold text-navy-800 leading-snug flex-1">{q}</dt>
            <span class="flex-shrink-0 mt-0.5 w-5 h-5 text-gray-400 group-open:rotate-45 transition-transform duration-200" aria-hidden="true">
              <svg viewBox="0 0 20 20" fill="currentColor">
                <path d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z"/>
              </svg>
            </span>
          </summary>
          <dd class="mt-3 text-sm text-gray-500 leading-relaxed">{a}</dd>
        </details>
      ))}
    </dl>
  </div>
</section>
