---
import { BRAND, NAV_LINKS, SERVICES, DIGITAL_PRODUCTS } from '@/lib/brand'
---

<footer class="bg-navy-900 text-navy-100 pt-14 pb-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Main grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 mb-10">
      <!-- Brand column -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-3 mb-4" aria-label="新亦源供应链首页">
          <div class="w-10 h-10 bg-brand-orange rounded-lg flex items-center justify-center text-white font-black text-xl flex-shrink-0">
            新
          </div>
          <div>
            <div class="text-white font-bold text-base leading-tight">新亦源供应链</div>
            <div class="text-navy-200 text-xs">{BRAND.tagline}</div>
          </div>
        </a>
        <p class="text-sm text-navy-200 leading-relaxed mb-5">
          2011年成立，深耕鞋服物流15年。140+知名服饰品牌的云仓伙伴，服务遍及全国6000+城市。
        </p>
        <div class="space-y-1.5">
          <a
            href={`tel:${BRAND.phone.direct}`}
            class="flex items-center gap-2 text-sm text-navy-100 hover:text-white transition-colors"
          >
            <svg class="w-4 h-4 text-brand-orange flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {BRAND.phone.direct}
          </a>
          <a
            href={`tel:${BRAND.phone.toll}`}
            class="flex items-center gap-2 text-sm text-navy-100 hover:text-white transition-colors"
          >
            <svg class="w-4 h-4 text-brand-orange flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {BRAND.phone.toll}（免费）
          </a>
        </div>
      </div>

      <!-- Products -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">产品服务</h3>
        <ul class="space-y-2.5">
          {SERVICES.map((s) => (
            <li>
              <a href={`/product#${s.id}`} class="text-sm text-navy-200 hover:text-white transition-colors">
                {s.name}
              </a>
            </li>
          ))}
          {DIGITAL_PRODUCTS.map((p) => (
            <li>
              <a href={`/product#${p.id}`} class="text-sm text-navy-200 hover:text-white transition-colors">
                {p.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">快速入口</h3>
        <ul class="space-y-2.5">
          {NAV_LINKS.map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm text-navy-200 hover:text-white transition-colors">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">联系与地址</h3>
        <ul class="space-y-3.5">
          <li class="text-sm">
            <span class="text-brand-orange font-medium">华南总部</span>
            <p class="text-navy-200 mt-0.5 leading-relaxed">{BRAND.locations.south.address}</p>
          </li>
          <li class="text-sm">
            <span class="text-navy-300 font-medium">华东仓</span>
            <p class="text-navy-200 mt-0.5 leading-relaxed">{BRAND.locations.east.address}</p>
          </li>
          <li class="text-sm">
            <span class="text-navy-300 font-medium">华中仓</span>
            <p class="text-navy-200 mt-0.5 leading-relaxed">{BRAND.locations.central.address}</p>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-navy-300">
        © {new Date().getFullYear()} {BRAND.fullName}. 保留所有权利.
      </p>
      <a
        href="https://beian.miit.gov.cn/"
        target="_blank"
        rel="noopener noreferrer"
        class="text-xs text-navy-300 hover:text-navy-100 transition-colors"
      >
        {BRAND.icp}
      </a>
    </div>
  </div>
</footer>
