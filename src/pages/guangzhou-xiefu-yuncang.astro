---
import ServiceLanding from '@/layouts/ServiceLanding.astro'

const WAREHOUSE_LIST = [
  {
    name: '广州黄埔主仓',
    tag: '华南总部',
    tagColor: 'bg-brand-orange text-white',
    address: '广州市黄埔区果园一路2号',
    area: '15,000 ㎡',
    traffic: '紧邻广园快速 + 京港澳高速，10台3吨货梯',
    coverage: '广州同城4小时达，广东全省次日达，全国主要城市次日–两日达',
    bestFor: 'B2C 全渠道高频出库 / 退货质检中心 / 唯品会联动运营',
  },
  {
    name: '广州番禺仓',
    tag: '番禺节点',
    tagColor: 'bg-navy-700 text-white',
    address: '广州市番禺区石楼镇市莲路石楼段6号',
    area: '3,000 ㎡',
    traffic: '番禺电商配送核心区，紧邻南沙港区',
    coverage: '广州南部极速配送，广东全省次日达',
    bestFor: '快时尚高SKU品牌 / 广州南部品牌前置仓',
  },
  {
    name: '东莞多仓',
    tag: '珠三角节点',
    tagColor: 'bg-navy-600 text-white',
    address: '东莞常平镇 / 桥头镇 / 朗州区（三仓联动）',
    area: '多仓联动',
    traffic: '紧邻莞深高速，珠三角制造业集中区',
    coverage: '珠三角次日达，广深港同日配',
    bestFor: 'OEM/ODM 工厂直出 / 珠三角制造业品牌就近仓储',
  },
  {
    name: '肇庆四会仓',
    tag: '唯品会专仓',
    tagColor: 'bg-green-600 text-white',
    address: '肇庆市四会市唯品会物流园（园区内）',
    area: '50,000 ㎡',
    traffic: '位于唯品会物流园内，多家快递公司驻仓，12米超高仓',
    coverage: '唯品会JIT/JITX园区内直发，华南大仓大促保障',
    bestFor: '唯品会 JIT/JITX 运营 / 大促弹性产能 / 规模化仓储',
  },
]
---

<ServiceLanding
  title="广州鞋服云仓 — 黄埔+番禺双仓，广州同城当日达，全国次日达 | 新亦源"
  description="新亦源广州鞋服云仓位于黄埔果园一路和番禺石楼，紧邻广园快速/京港澳高速，广州同城4小时达，18:00截单当日24:00全出，支持B2C+B2B+退货质检全业务。"
  slug="guangzhou-xiefu-yuncang"
  breadcrumbLabel="广州鞋服云仓"
  eyebrow="广州鞋服云仓 · 黄埔+番禺双仓布局"
  h1="广州鞋服云仓"
  h1sub="广州本地仓储，同城当日达，次日全国达"
  heroDesc="新亦源广州鞋服云仓覆盖黄埔区和番禺区两个核心节点，紧邻广园快速/京港澳高速，广州同城4小时达，支持B2C/B2B/O2O全渠道及退货质检全业务。"
  imgSrc="/index.webp"
  imgAlt="广州鞋服云仓 — 广州本地仓储配送"
  stats={[
    { stat: '广州双仓', label: '黄埔+番禺布局', sub: '总面积超1.8万㎡' },
    { stat: '4小时', label: '广州同城配送', sub: '广州本地极速达' },
    { stat: '18:00截单', label: '当日24:00全出', sub: 'SLA合同保障' },
    { stat: '0元', label: '系统接入费', sub: '奇门/EDI免费对接' },
  ]}
  contentDesc="适合主要销售市场在广州及珠三角的鞋服品牌。广州本地仓配分散、大促时效无保障是主要痛点。新亦源广州覆盖黄埔主仓（果园一路2号）+番禺卫星仓双节点，广州同城4小时达、广东全省次日达，10台3吨货梯保障进出货效率，B2C电商与B2B门店全渠道均可承接，开仓即用。"
  featuresLabel="核心能力"
  features={[
    { title: '广州双仓覆盖', desc: '黄埔果园一路主仓+番禺石楼卫星仓，双仓互为备援，根据订单量和商品属性灵活调配，避免单仓爆仓。' },
    { title: '广州同城极速达', desc: '广州本地订单可实现4小时内配送，支持O2O门店紧急补货、同城B2C订单极速履约，满足商超/门店/直播即时需求。' },
    { title: '全渠道广州仓配', desc: '广州仓支持B2C（天猫/京东/拼多多等）+B2B（批发/连锁门店补货）+O2O（广州本地门店库存融合），全渠道一盘货管理。' },
    { title: '广州退货质检中心', desc: '黄埔主仓设专属退货质检与后整修复区，广州/广东区域退货就近处理，48小时内完成质检和二次上架。' },
    { title: '零门槛系统接入', desc: '与天猫/京东/唯品会/抖音等主流平台奇门/EDI接口免费对接，与品牌方ERP/OMS免费打通，上线周期1-2周。' },
    { title: '广州本地服务支持', desc: '专属广州BD经理，可上门洽谈方案，方便广州本地品牌和制造商快速开始合作，首单免费试运营支持。' },
  ]}
  faqs={[
    {
      q: '新亦源广州仓位置在哪里，交通方便吗？',
      a: '两个位置：①黄埔仓：广州市黄埔区果园一路2号，紧邻广园快速出口和京港澳高速，货车进出极为方便；②番禺仓：番禺区石楼镇市莲路石楼段6号，番禺电商集散核心区，适合广州南部品牌就近配货。',
    },
    {
      q: '广州仓能做同城当日达吗？',
      a: '可以。广州仓支持同城极速配送，与广州本地即时物流/同城快递合作，广州市区订单最快4小时内送达，适合O2O线下门店补货、直播订单即时发货场景。标准B2C订单按18:00截单当日24:00全出的SLA执行。',
    },
    {
      q: '广州仓适合什么类型的鞋服品牌？',
      a: '特别适合：①广州本地品牌/工厂，减少货物入库运输成本；②主要消费市场在华南的品牌，利用广州仓的时效优势；③有大量唯品会运营的品牌，广州仓联动肇庆唯品会园区仓运营；④O2O运营有广州门店需求的品牌；⑤跨境出海品牌，利用广州港/白云机场的国际物流优势。',
    },
    {
      q: '广州仓的规模是多少？能支持大促爆单吗？',
      a: '广州黄埔主仓：使用面积15,000㎡，配10台3吨货梯；番禺仓：使用面积3,000㎡+，可按需扩展。结合东莞/肇庆仓，华南地区合计峰值处理能力超100万件/日。大促期间启动弹性人力机制，历史无因仓容问题导致SLA违约记录。',
    },
    {
      q: '新亦源广州仓收费模式是什么？',
      a: '广州仓采用按需计费模式：仓储费按实际占用面积/货位计算；操作费按入/出库件数计算；系统费0元（含平台接口对接）；退货质检和修复按服务量单独计费。没有最低月费要求，适合不同规模品牌。具体报价根据商品品类、SKU数量和预计吞吐量定制，建议联系广州本地商务团队。',
    },
  ]}
>
  <section slot="unique" class="py-14 bg-gray-50 border-b border-gray-100" aria-labelledby="warehouse-map-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="warehouse-map-heading" class="text-xl font-black text-navy-800 mb-1 text-center">广州 · 东莞 · 肇庆仓点覆盖详情</h2>
      <p class="text-xs text-gray-400 text-center mb-8">华南四大仓点联动，覆盖珠三角所有主要配送场景</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {WAREHOUSE_LIST.map(({ name, tag, tagColor, address, area, traffic, coverage, bestFor }) => (
          <div class="bg-white rounded-xl border border-gray-200 p-5 flex flex-col gap-3">
            <div>
              <span class={`inline-block text-[10px] font-black px-2 py-0.5 rounded-full mb-2 ${tagColor}`}>{tag}</span>
              <h3 class="font-black text-navy-800 text-base">{name}</h3>
              <p class="text-xs text-gray-400 mt-0.5">{address}</p>
            </div>
            <div class="space-y-2 text-xs">
              <div class="flex gap-2">
                <span class="text-gray-400 shrink-0 w-12">面积</span>
                <span class="font-bold text-navy-800">{area}</span>
              </div>
              <div class="flex gap-2">
                <span class="text-gray-400 shrink-0 w-12">交通</span>
                <span class="text-gray-600 leading-snug">{traffic}</span>
              </div>
              <div class="flex gap-2">
                <span class="text-gray-400 shrink-0 w-12">时效</span>
                <span class="text-gray-600 leading-snug">{coverage}</span>
              </div>
            </div>
            <div class="pt-2 border-t border-gray-100">
              <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1">最适合</p>
              <p class="text-xs text-navy-700 font-medium leading-snug">{bestFor}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</ServiceLanding>
