---
// SSR: no prerender, fetches fresh article on each request
import Layout from '@/layouts/Layout.astro'
import { BRAND } from '@/lib/brand'
import { getNewsArticle, getPublishedNews, formatDate, getDirectusAssetUrl } from '@/lib/directus'
import { sanitizeRichText } from '@/lib/sanitize'

const { slug } = Astro.params as { slug: string }

const article = await getNewsArticle(slug)

if (!article) {
  return Astro.redirect('/news', 302)
}

const relatedArticles = await getPublishedNews(3, 1)
const related = relatedArticles.filter((a) => a.slug !== slug).slice(0, 3)
const sanitizedContent = sanitizeRichText(article.content ?? '')

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  '@id': `${BRAND.url}/news/${article.slug}`,
  headline: article.title,
  description: article.summary,
  datePublished: article.published_at,
  dateModified: article.date_updated ?? article.published_at,
  author: {
    '@type': 'Organization',
    name: BRAND.fullName,
    url: BRAND.url,
  },
  publisher: {
    '@type': 'Organization',
    name: BRAND.name,
    logo: { '@type': 'ImageObject', url: `${BRAND.url}/logo.png` },
  },
  url: `${BRAND.url}/news/${article.slug}`,
  mainEntityOfPage: { '@type': 'WebPage', '@id': `${BRAND.url}/news/${article.slug}` },
  ...(article.cover_image && {
    image: getDirectusAssetUrl(article.cover_image),
  }),
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: BRAND.url },
    { '@type': 'ListItem', position: 2, name: '行业动态', item: `${BRAND.url}/news` },
    { '@type': 'ListItem', position: 3, name: article.title, item: `${BRAND.url}/news/${article.slug}` },
  ],
}
---

<Layout
  title={article.title}
  description={article.summary}
  canonical={`${BRAND.url}/news/${article.slug}`}
  ogImage={article.cover_image
    ? getDirectusAssetUrl(article.cover_image)
    : undefined}
  jsonLd={[articleSchema, breadcrumbSchema]}
>
  <!-- Breadcrumb -->
  <nav class="bg-gray-50 border-b border-gray-100 py-3" aria-label="面包屑导航">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <ol class="flex items-center gap-2 text-sm text-gray-500" vocab="https://schema.org/" typeof="BreadcrumbList">
        <li property="itemListElement" typeof="ListItem">
          <a href="/" property="item" typeof="WebPage" class="hover:text-navy-800 transition-colors">
            <span property="name">首页</span>
          </a>
          <meta property="position" content="1" />
        </li>
        <li aria-hidden="true"><svg class="w-3 h-3 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg></li>
        <li property="itemListElement" typeof="ListItem">
          <a href="/news" property="item" typeof="WebPage" class="hover:text-navy-800 transition-colors">
            <span property="name">行业动态</span>
          </a>
          <meta property="position" content="2" />
        </li>
        <li aria-hidden="true"><svg class="w-3 h-3 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg></li>
        <li property="itemListElement" typeof="ListItem" class="text-gray-700 font-medium truncate max-w-xs">
          <span property="name">{article.title}</span>
          <meta property="position" content="3" />
        </li>
      </ol>
    </div>
  </nav>

  <!-- Article -->
  <article class="py-12 bg-white" itemscope itemtype="https://schema.org/NewsArticle">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <header class="mb-8">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-xs font-bold text-brand-orange bg-orange-50 px-3 py-1.5 rounded-full" itemprop="articleSection">
            {article.category}
          </span>
          <time
            class="text-sm text-gray-400"
            datetime={article.published_at}
            itemprop="datePublished"
          >
            {formatDate(article.published_at)}
          </time>
        </div>
        <h1 class="text-3xl lg:text-4xl font-black text-navy-900 leading-tight mb-5" itemprop="headline">
          {article.title}
        </h1>
        <p class="text-lg text-gray-600 leading-relaxed border-l-4 border-brand-orange pl-5 italic" itemprop="description">
          {article.summary}
        </p>
      </header>

      <!-- Cover Image -->
      {article.cover_image && (
        <figure class="mb-10 rounded-2xl overflow-hidden aspect-video">
          <img
            src={getDirectusAssetUrl(article.cover_image)}
            alt={article.title}
            width="800"
            height="450"
            class="w-full h-full object-cover"
            itemprop="image"
            fetchpriority="high"
          />
        </figure>
      )}

      <!-- Content -->
      <div
        class="prose prose-lg max-w-none prose-headings:text-navy-800 prose-headings:font-bold prose-a:text-navy-700 prose-a:underline prose-strong:text-navy-800 prose-blockquote:border-brand-orange"
        itemprop="articleBody"
        set:html={sanitizedContent}
      />

      <!-- Meta footer -->
      <footer class="mt-12 pt-8 border-t border-gray-100">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-lg bg-brand-orange/10 flex items-center justify-center flex-shrink-0">
            <span class="text-brand-orange font-black text-sm">新</span>
          </div>
          <div>
            <p class="text-sm font-semibold text-gray-800" itemprop="author" itemscope itemtype="https://schema.org/Organization">
              <span itemprop="name">{BRAND.fullName}</span>
            </p>
            <p class="text-xs text-gray-400">鞋服云仓专业服务商 · 深耕15年</p>
          </div>
        </div>
      </footer>
    </div>
  </article>

  <!-- Related Articles -->
  {related.length > 0 && (
    <section class="py-12 bg-gray-50 border-t border-gray-100" aria-labelledby="related-heading">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 id="related-heading" class="text-xl font-bold text-navy-800 mb-7">相关文章</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          {related.map((a) => (
            <article class="bg-white rounded-xl border border-gray-100 p-5 hover:border-navy-200 hover:shadow-md transition-all">
              <span class="text-xs font-bold text-brand-orange">{a.category}</span>
              <h3 class="text-sm font-bold text-navy-800 mt-2 mb-2 leading-snug line-clamp-2">
                <a href={`/news/${a.slug}`} class="hover:text-brand-orange transition-colors">{a.title}</a>
              </h3>
              <time class="text-xs text-gray-400" datetime={a.published_at}>{formatDate(a.published_at)}</time>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Back link -->
  <div class="py-8 bg-white border-t border-gray-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <a href="/news" class="inline-flex items-center text-sm font-semibold text-navy-700 hover:text-brand-orange transition-colors">
        <svg class="mr-2 w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        返回行业动态
      </a>
    </div>
  </div>
</Layout>

<style>
  .line-clamp-2 { overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
</style>
