---
// No prerender = SSR, fetches fresh from Directus on each request
import Layout from '@/layouts/Layout.astro'
import PageFAQ from '@/components/PageFAQ.astro'
import { BRAND } from '@/lib/brand'
import { getPublishedNews, formatDate, NEWS_CATEGORIES, getDirectusAssetUrl } from '@/lib/directus'
import type { NewsArticle } from '@/lib/directus'

const page = Number(Astro.url.searchParams.get('page') ?? '1')
const category = Astro.url.searchParams.get('cat') ?? ''
const PAGE_SIZE = 12

let articles: NewsArticle[]
try {
  articles = await getPublishedNews(PAGE_SIZE, page)
  if (category) {
    articles = articles.filter((a) => a.category === category)
  }
} catch {
  articles = []
}

const PLACEHOLDER_ARTICLES = [
  {
    id: 0,
    title: '鞋服行业618大促物流备战指南：如何在旺季保障发货时效？',
    slug: 'guide-618-logistics',
    summary: '每年618是鞋服云仓的高峰压测。本文整理了爆仓预防、弹性产能调配、波次拣货优化等实操经验，帮助品牌商提前规划大促物流方案。',
    category: '物流干货',
    published_at: '2026-06-10T00:00:00.000Z',
  },
  {
    id: 0,
    title: '退货率高达40%？鞋服电商退货质检的正确打开方式',
    slug: 'returns-quality-inspection',
    summary: '退货商品经过专业质检+瑕疵修复，平均可减少20%+的库存损耗。本文介绍AQL标准质检流程和48小时二次上架的实现路径。',
    category: '物流干货',
    published_at: '2026-06-05T00:00:00.000Z',
  },
  {
    id: 0,
    title: '唯品会JIT/JITX对接详解：鞋服品牌必知的供应链要求',
    slug: 'vip-jit-guide',
    summary: '唯品会JIT模式对库存精准度、响应时效有严苛要求。本文从入仓标准、拣货流程到扣分机制，全面解读如何高效对接唯品会JIT/JITX。',
    category: '行业资讯',
    published_at: '2026-06-01T00:00:00.000Z',
  },
] as NewsArticle[]

const displayArticles = articles.length > 0 ? articles : PLACEHOLDER_ARTICLES

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: BRAND.url },
    { '@type': 'ListItem', position: 2, name: '行业动态', item: `${BRAND.url}/news` },
  ],
}
---

<Layout
  title="行业动态 - 鞋服物流资讯 | 新亦源供应链"
  description="新亦源供应链行业动态，涵盖鞋服物流干货、行业资讯、政策解读与新亦源动态。了解云仓、质检修复、物流云最新资讯，助力品牌供应链决策。"
  jsonLd={breadcrumbSchema}
>
  <!-- Hero -->
  <section class="relative py-16 overflow-hidden" aria-labelledby="news-hero-heading">
    <img
      src="/w-hq.webp"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover object-center"
      fetchpriority="high"
    />
    <div
      class="absolute inset-0"
      style="background: linear-gradient(105deg, rgba(8,20,42,0.96) 0%, rgba(8,20,42,0.82) 45%, rgba(8,20,42,0.50) 100%);"
      aria-hidden="true"
    ></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-brand-orange font-semibold text-sm tracking-wider uppercase mb-3">行业动态</p>
      <h1 id="news-hero-heading" class="text-4xl lg:text-5xl font-black text-white leading-tight mb-4">
        鞋服物流知识库
      </h1>
      <p class="text-lg text-navy-100 max-w-2xl">
        持续更新行业资讯、操作干货、政策解读、新亦源动态相关内容
      </p>
    </div>
  </section>

  <!-- Category Filter -->
  <div class="bg-white border-b border-gray-100 sticky top-16 z-40" role="navigation" aria-label="文章分类筛选">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-2 overflow-x-auto py-3 no-scrollbar">
        <a
          href="/news"
          class:list={[
            'flex-shrink-0 px-4 py-1.5 rounded-full text-sm font-medium transition-colors',
            !category
              ? 'bg-navy-800 text-white'
              : 'text-gray-600 hover:text-navy-800 hover:bg-gray-100',
          ]}
        >
          全部
        </a>
        {NEWS_CATEGORIES.map((cat) => (
          <a
            href={`/news?cat=${encodeURIComponent(cat)}`}
            class:list={[
              'flex-shrink-0 px-4 py-1.5 rounded-full text-sm font-medium transition-colors',
              category === cat
                ? 'bg-navy-800 text-white'
                : 'text-gray-600 hover:text-navy-800 hover:bg-gray-100',
            ]}
          >
            {cat}
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- 森林期刊入口 Banner -->
  <div class="bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5">
      <a
        href="/senlinqikan"
        class="group flex items-center gap-5 bg-navy-50 hover:bg-navy-100 rounded-2xl px-6 py-4 transition-colors"
      >
        <div class="flex-shrink-0 w-16 h-16 rounded-xl overflow-hidden">
          <img src="/senlinqikan/covers/14.jpg" alt="森林期刊" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1">
            <span class="text-[11px] font-bold text-brand-orange bg-orange-50 px-2 py-0.5 rounded-full">新亦源出品</span>
            <span class="text-xs text-gray-400">第1–14期</span>
          </div>
          <p class="text-sm font-black text-navy-800 truncate">🌲 森林期刊 — 鞋服供应链行业内刊，14期内容免费下载</p>
          <p class="text-xs text-gray-400 mt-0.5 truncate hidden sm:block">聚焦云仓运营、退货质检、直播仓配、行业趋势与品牌动态</p>
        </div>
        <svg class="w-5 h-5 text-gray-400 flex-shrink-0 group-hover:text-navy-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>

  <!-- Articles Grid -->
  <section class="py-12 bg-gray-50" aria-label="文章列表">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {displayArticles.map((article) => (
          <article class="bg-white rounded-2xl border border-gray-100 overflow-hidden hover:border-navy-200 hover:shadow-lg transition-all duration-300 flex flex-col">
            {article.cover_image && (
              <div class="aspect-video overflow-hidden">
                <img
                  src={getDirectusAssetUrl(article.cover_image)}
                  alt={article.title}
                  loading="lazy"
                  decoding="async"
                  width="400"
                  height="225"
                  class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                />
              </div>
            )}
            {!article.cover_image && (
              <div class="aspect-video bg-gradient-to-br from-navy-900 to-navy-700 flex items-center justify-center">
                <span class="text-navy-400 text-sm font-medium">{article.category || '行业动态'}</span>
              </div>
            )}
            <div class="p-6 flex flex-col flex-1">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-xs font-bold text-brand-orange bg-orange-50 px-2.5 py-1 rounded-full">
                  {article.category || '行业资讯'}
                </span>
                <time
                  class="text-xs text-gray-400"
                  datetime={article.published_at}
                >
                  {formatDate(article.published_at)}
                </time>
              </div>
              <h2 class="text-base font-bold text-navy-800 leading-snug mb-3 flex-1 line-clamp-2">
                <a
                  href={`/news/${article.slug}`}
                  class="hover:text-brand-orange transition-colors"
                >
                  {article.title}
                </a>
              </h2>
              <p class="text-sm text-gray-500 leading-relaxed line-clamp-2 mb-4">{article.summary}</p>
              <a
                href={`/news/${article.slug}`}
                class="inline-flex items-center text-sm font-semibold text-navy-700 hover:text-brand-orange transition-colors mt-auto"
                aria-label={`阅读全文：${article.title}`}
              >
                阅读全文
                <svg class="ml-1 w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>

      <!-- Pagination placeholder -->
      {articles.length === PAGE_SIZE && (
        <div class="text-center mt-10">
          <a
            href={`/news?page=${page + 1}${category ? `&cat=${encodeURIComponent(category)}` : ''}`}
            class="inline-flex items-center px-6 py-3 border border-gray-300 hover:border-navy-400 text-gray-700 hover:text-navy-800 font-semibold rounded-xl text-sm transition-colors"
          >
            加载更多
            <svg class="ml-2 w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </a>
        </div>
      )}
    </div>
  </section>

  <!-- FAQ -->
  <PageFAQ
    heading="行业动态常见问题"
    items={[
      { q: '新亦源行业动态栏目的内容由谁撰写？', a: '内容由新亦源内部运营团队、供应链顾问及行业合作专家共同出品。所有文章均基于真实仓配操作数据、品牌合作积累及公开行业数据，不接受任何形式的付费软文发布。' },
      { q: '文章中提到的"波次拣货"是什么意思？对发货时效有什么影响？', a: '波次拣货是将一段时间内的订单按照拣货路径、SKU集中度进行批量合并，由拣货员一次性完成多个订单的拣选动作，而非逐单处理。这种方式可将单仓日处理能力提升30%–50%，同时降低拣货错误率。对品牌而言，波次管理是大促当天出库量能否达峰的关键决定因素。' },
      { q: 'B2B批发配货和B2C电商发货，仓库操作逻辑有什么根本区别？', a: '两种模式在仓内的核心差异体现在三个层面：①拣货颗粒度——B2C按单件拣货，精准到款色码；B2B按整箱或整托拣货，强调体积和重量控制；②包装标准——B2C面向消费者，需精装外包装和防损保护；B2B以效率优先，通常走栈板或大纸箱集货；③库存管理——B2C需实时扣减库存防超卖，B2B可接受周期性批次更新。新亦源WMS支持在同一仓点区分B2C和B2B货区，品牌同时运营两种渠道时系统自动按渠道走不同的拣配SOP。' },
      { q: '唯品会JIT/JITX模式对仓库有什么具体要求？为什么很多品牌觉得难对接？', a: 'JIT（Just-In-Time）要求品牌在唯品会活动开始后，按照其实时下单量进行精准发货，不允许提前备货。JITX在此基础上进一步要求在规定时间窗内完成出库。主要挑战有：①库存数据需与唯品会系统实时同步，精准率要求≥99.5%；②出库时效要求严格，通常T+1日必须扫描上网；③超时或发错会触发扣分，严重影响商家评级。新亦源通过OTD中台实现与唯品会的直连对接，目前已有多个品牌稳定运营JIT/JITX模式。' },
      { q: '直播电商的仓配逻辑和传统电商有什么本质区别？', a: '传统电商订单分散、可预测，按历史波形规划产能；直播电商订单高度集中（直播结束后30–120分钟内爆量），且实时无法精准预测。仓配层面的核心差异：①需要专属"直播仓区"预置当场货位，减少拣货路径；②人力需按场次弹性调配，不能按固定班次排；③出库SLA通常要求比普通订单更短（部分平台要求4小时内出库）。新亦源已形成标准化的直播场次仓配SOP，配合品牌做场前预布。' },
      { q: '文章提到的"逆向物流"是什么概念？和退货处理是一回事吗？', a: '"逆向物流"是指商品从消费者端流回品牌/仓库的全链路，退货处理是其核心环节之一。但逆向物流还包括：退件运输管理、到仓验收、质检分级、修复翻新、二次上架或报废处置，以及退货数据统计与原因分析。新亦源的逆向物流体系将退货全流程纳入SLA管理，而非仅做"收货+上架"的动作，从而帮助品牌将退货变为可二次利用的资产。' },
      { q: '如何订阅新亦源行业动态的更新通知？', a: '目前可通过以下方式获取内容更新：关注新亦源官方公众号（搜索"新亦源供应链"）；或通过官网联系页面留下邮箱，加入定期推送名单。我们通常每月输出4–8篇深度文章，不做流量填充，每篇均有实际操作参考价值。' },
      { q: '我看到了一篇对我有参考价值的文章，可以转发给同事或行业伙伴吗？', a: '欢迎转发。您可以直接分享文章链接，或将内容截图/摘录用于内部培训和团队学习，无需额外授权。如需将文章内容用于媒体刊载、公开出版或白皮书引用，请注明来源"新亦源供应链"并通过官网联系我们。我们鼓励知识在行业中流通，但希望确保来源可溯。' },
    ]}
  />

  <!-- CTA -->
  <section class="py-12 bg-white border-t border-gray-100" aria-label="订阅与联系">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-xl font-bold text-navy-800 mb-3">想了解适合您品类的物流方案？</h2>
      <p class="text-gray-600 text-sm mb-6">我们的物流顾问可以为您提供定制分析，免费咨询</p>
      <a
        href="/contact"
        class="inline-flex items-center px-6 py-3 bg-brand-orange hover:bg-brand-orange-dark text-white font-bold rounded-xl text-sm transition-colors"
      >
        免费获取方案
      </a>
    </div>
  </section>
</Layout>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  .line-clamp-2 { overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
</style>
