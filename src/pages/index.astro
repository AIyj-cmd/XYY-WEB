  border: 1.5px solid #0A1A33;
  color: #0A1A33;
  padding: 0.75rem 2rem;
  border-radius: 999px;
  font-size: 0.875rem;
  font-weight: 700;
  text-decoration: none;
  letter-spacing: 0.03em;
  transition: background 0.22s, color 0.22s;
}
.btn-outline-dark:hover { background: #0A1A33; color: #fff; }

@media (max-width: 900px) {
  .cl-row {
    grid-template-columns: 2.5rem 1fr 1fr;
    grid-template-rows: auto auto;
    column-gap: 1.5rem;
    row-gap: 1rem;
  }
  .cl-metric { grid-column: 3; grid-row: 1; justify-self: end; }
  .cl-tags   { grid-column: 2 / 4; grid-row: 2; }
  .cl-arrow  { display: none; }
}
@media (max-width: 560px) {
  .cl-row {
    grid-template-columns: 2.5rem 1fr;
    grid-template-rows: auto auto auto;
  }
  .cl-metric { grid-column: 2; grid-row: 2; justify-self: start; }
  .cl-tags   { grid-column: 2; grid-row: 3; }
}

/* ── Case Modal ─────────────────────────────────────────────── */
.case-modal {
  position: fixed;
  inset: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 1rem;
}
.case-modal[hidden] { display: none; }
.modal-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(5,15,35,0.75);
  backdrop-filter: blur(8px);
}
.modal-panel {
  position: relative;
  z-index: 1;
  background: #fff;
  border-radius: 1.75rem;
  max-width: 760px;
  width: 100%;
  max-height: 92vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: 0 40px 100px rgba(0,0,0,0.45);
  opacity: 0;
  transform: translateY(28px) scale(0.96);
  transition: opacity 0.28s cubic-bezier(0.16,1,0.3,1), transform 0.28s cubic-bezier(0.16,1,0.3,1);
}
.modal-panel.visible { opacity: 1; transform: translateY(0) scale(1); }

/* Hero image */
.modal-hero {
  position: relative;
  height: 200px;
  overflow: hidden;
  border-radius: 1.75rem 1.75rem 0 0;
  flex-shrink: 0;
}
.modal-hero-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 30%;
}
.modal-hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    165deg,
    rgba(5,15,35,0.25) 0%,
    rgba(5,15,35,0.65) 60%,
    rgba(5,15,35,0.88) 100%
  );
}
.modal-hero-content {
  position: absolute;
  bottom: 1.75rem;
  left: 2rem;
  right: 4rem;
}
.modal-category-tag {
  display: inline-block;
  font-size: 0.65rem;
  font-weight: 800;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #fff;
  background: var(--modal-accent, #2563EB);
  padding: 0.25rem 0.75rem;
  border-radius: 999px;
  margin-bottom: 0.625rem;
  opacity: 0.95;
}
.modal-title {
  font-size: clamp(1.5rem, 4vw, 2rem);
  font-weight: 900;
  color: #fff;
  line-height: 1.2;
  text-shadow: 0 2px 12px rgba(0,0,0,0.3);
}
.modal-close {
  position: absolute;
  top: 1.25rem;
  right: 1.25rem;
  width: 2.25rem;
  height: 2.25rem;
  border-radius: 50%;
  border: none;
  background: rgba(255,255,255,0.2);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  backdrop-filter: blur(4px);
  transition: background 0.15s;
  z-index: 2;
}
.modal-close:hover { background: rgba(255,255,255,0.35); }

/* Body */
.modal-body {
  padding: 1.5rem 2rem 1.75rem;
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: #CBD5E1 transparent;
}
.modal-desc {
  font-size: 0.9rem;
  color: #475569;
  line-height: 1.75;
  margin-bottom: 1.25rem;
  padding-bottom: 1.25rem;
  border-bottom: 1px solid #F1F5F9;
}

/* Stats */
.modal-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  row-gap: 1.5rem;
  padding: 1.25rem 0;
  border-top: 1px solid #F1F5F9;
  border-bottom: 1px solid #F1F5F9;
  margin-bottom: 1.5rem;
}
@media (max-width: 520px) {
  .modal-stats { grid-template-columns: repeat(2, 1fr); }
  :global(.modal-stat-card:nth-child(2n)) { border-right: none; }
}
:global(.modal-stat-card) {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.15rem;
  padding: 0 0.5rem;
  border-right: 1px solid #F1F5F9;
  text-align: center;
}
:global(.modal-stat-card:nth-child(4n)),
:global(.modal-stat-card:last-child) { border-right: none; }
:global(.modal-stat-val) {
  font-size: clamp(1.2rem, 2.5vw, 1.6rem);
  font-weight: 900;
  color: var(--modal-accent, #2563EB);
  line-height: 1;
  letter-spacing: -0.03em;
}
:global(.modal-stat-unit) {
  font-size: 0.58rem;
  color: color-mix(in srgb, var(--modal-accent, #2563EB) 55%, #9CA3AF);
  font-weight: 700;
  letter-spacing: 0.03em;
  display: block;
}
:global(.modal-stat-label) {
  font-size: 0.62rem;
  color: #94A3B8;
  line-height: 1.3;
}


.btn-outline-light {
  display: inline-flex;
  align-items: center;
  padding: 0.875rem 2rem;
  border: 2px solid rgba(255,255,255,0.3);
  color: #fff;
  font-weight: 600;
  border-radius: 0.75rem;
  font-size: 0.95rem;
  text-decoration: none;
  transition: border-color 0.2s, background 0.2s;
}
.btn-outline-light:hover { border-color: #fff; background: rgba(255,255,255,0.08); }

/* ── ⑥ Order Fulfillment ─────────────────────────────────────── */
.s-fulfillment {
  background: #f8fafc;
  padding: 6rem 2rem;
  overflow: hidden;
  position: relative;
}
.fulfillment-header {
  max-width: 820px;
  margin: 0 auto 5rem;
  text-align: center;
}
.fulfillment-title {
  font-size: clamp(1.75rem, 3vw, 2.5rem);
  font-weight: 900;
  color: #0A1A33;
  line-height: 1.2;
  margin-bottom: 1.25rem;
}
.fulfillment-sub {
  font-size: 1rem;
  color: #475569;
  line-height: 1.8;
}
.fulfillment-track {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 0;
  max-width: 1400px;
  margin: 0 auto;
  row-gap: 3rem;
}
.fulfillment-step {
  flex: 0 0 clamp(180px, 14.2%, 220px);
  position: relative;
  padding: 0 1rem 0 0;
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0s;
}
/* horizontal connecting line */
.fulfillment-connector {
  position: absolute;
  top: 2rem;
  left: 4rem;
  right: 0;
  height: 1px;
  background: #e2e8f0;
  overflow: hidden;
}
.fulfillment-connector::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, #E85D26 0%, #f97316 100%);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  transition-delay: calc(var(--i) * 0.12s + 0.3s);
}
.s-fulfillment.is-visible .fulfillment-connector::after {
  transform: scaleX(1);
}
.fulfillment-step:last-child .fulfillment-connector { display: none; }

/* number badge */
.fulfillment-num-wrap {
  position: relative;
  display: inline-block;
  margin-bottom: 1.5rem;
}
.fulfillment-num {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 4rem;
  height: 4rem;
  border: 2px solid #E85D26;
  border-radius: 50%;
  color: #E85D26;
  font-size: 0.875rem;
  font-weight: 900;
  letter-spacing: 0.08em;
  position: relative;
  z-index: 1;
  background: #fff;
  transition: background 0.3s, color 0.3s, box-shadow 0.3s;
}
/* pulsing ring */
.fulfillment-num-ring {
  position: absolute;
  inset: -6px;
  border-radius: 50%;
  border: 1.5px solid rgba(232,93,38,0.3);
  opacity: 0;
  transform: scale(0.8);
  transition: opacity 0.3s, transform 0.3s;
}
.fulfillment-step:hover .fulfillment-num {
  background: #E85D26;
  color: #fff;
  box-shadow: 0 0 0 6px rgba(232,93,38,0.15), 0 8px 24px rgba(232,93,38,0.3);
}
.fulfillment-step:hover .fulfillment-num-ring {
  opacity: 1;
  transform: scale(1);
}
.fulfillment-step-title {
  font-size: 1rem;
  font-weight: 800;
  color: #0A1A33;
  margin-bottom: 0.6rem;
  line-height: 1.4;
  transition: color 0.2s;
}
.fulfillment-step:hover .fulfillment-step-title { color: #E85D26; }
.fulfillment-step-desc {
  font-size: 0.825rem;
  color: #475569;
  line-height: 1.7;
  max-width: 180px;
}
@media (max-width: 768px) {
  .s-fulfillment { padding: 4rem 1.5rem; }
  .fulfillment-step { flex: 0 0 45%; }
  .fulfillment-connector { display: none; }
}

/* ── ⑦ CTA ───────────────────────────────────────────────────── */
/* ── FAQ ─────────────────────────────────────────────────── */
.s-faq {
  padding: 6rem 2rem;
  background: #fff;
}
.faq-inner {
  max-width: 800px;
  margin: 0 auto;
}
.faq-inner .section-title { margin-bottom: 3rem; }
.faq-list { list-style: none; margin: 0; padding: 0; }
.faq-item {
  border-top: 1px solid #e2e8f0;
  padding: 1.75rem 0;
}
.faq-item:last-child { border-bottom: 1px solid #e2e8f0; }
.faq-q {
  font-size: 1.05rem;
  font-weight: 700;
  color: #0A1A33;
  margin: 0 0 0.75rem;
  line-height: 1.4;
}
.faq-a {
  font-size: 0.95rem;
  color: #475569;
  line-height: 1.8;
  margin: 0;
}
.faq-authority {
  margin-top: 2rem;
  font-size: 0.75rem;
  color: #94a3b8;
}
.faq-authority a {
  color: inherit;
  text-decoration: underline;
  text-underline-offset: 2px;
  transition: color 0.15s;
}
.faq-authority a:hover { color: #64748b; }

.s-cta {
  min-height: 80vh;
  background: #EFF4FF;
  display: flex;
  align-items: center;
  padding: 6rem 2rem;
  text-align: center;
}
.cta-inner { max-width: 700px; margin: 0 auto; opacity: 0; transform: translateY(40px); }
.cta-title {
  font-size: clamp(1.75rem, 3vw, 2.5rem);
  font-weight: 900;
  color: #0A1A33;
  line-height: 1.25;
  margin-bottom: 1rem;
}
.cta-sub { font-size: 1rem; color: #475569; margin-bottom: 2.5rem; }
.cta-phones {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  flex-wrap: wrap;
  margin-bottom: 2rem;
}
.phone-link {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-size: clamp(1.2rem, 2vw, 1.6rem);
  font-weight: 800;
  color: #0A1A33;
  text-decoration: none;
  transition: color 0.2s;
}
.phone-link:hover { color: #2563EB; }
.phone-sep { font-size: 1.5rem; color: #94a3b8; }
.btn-cta {
  display: inline-flex;
  align-items: center;
  padding: 1rem 2.5rem;
  background: #2563EB;
  color: #fff;
  font-weight: 700;
  border-radius: 0.75rem;
  font-size: 1.1rem;
  text-decoration: none;
  box-shadow: 0 8px 30px rgba(37,99,235,0.35);
  transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
}
.btn-cta:hover {
  background: #1d4ed8;
  transform: translateY(-2px);
  box-shadow: 0 12px 40px rgba(37,99,235,0.45);
}
.cta-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 0.875rem;
  margin-top: 0.25rem;
}
.btn-cta-ghost {
  display: inline-flex;
  align-items: center;
  padding: 1rem 2rem;
  border: 2px solid rgba(255,255,255,0.35);
  color: #fff;
  font-weight: 700;
  border-radius: 0.75rem;
  font-size: 1.0rem;
  text-decoration: none;
  transition: border-color 0.2s, background 0.2s;
}
.btn-cta-ghost:hover {
  border-color: rgba(255,255,255,0.7);
  background: rgba(255,255,255,0.08);
}

/* ── Mobile adjustments ──────────────────────────────────────── */
@media (max-width: 768px) {
  .svc-body { padding: 2.5rem 1.5rem; }
  .s-stats { padding: 4rem 1.5rem; }

}
</style>

<script>
import gsap from 'gsap'
import { ScrollTrigger } from 'gsap/ScrollTrigger'
import Lenis from 'lenis'

gsap.registerPlugin(ScrollTrigger)

// ── Lenis smooth scroll ──────────────────────────────────────
const lenis = new Lenis({ lerp: 0.08, smoothWheel: true })
lenis.on('scroll', ScrollTrigger.update)
gsap.ticker.add((t) => lenis.raf(t * 1000))
gsap.ticker.lagSmoothing(0)

// ── Hero reveal on load ──────────────────────────────────────
const heroTl = gsap.timeline({ delay: 0.3 })
heroTl
  .to('.hero-eyebrow', { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' }, 0)
  .to('.hero-title .hl', {
    opacity: 1, y: 0,
    stagger: 0.15, duration: 0.75, ease: 'power3.out',
  }, 0.25)
  .to('.hero-sub', { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' }, 0.6)
  .to('.hero-actions', { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' }, 0.8)

// Set initial y for hero elements
gsap.set('.hero-eyebrow, .hero-title .hl, .hero-sub, .hero-actions', { y: 30 })

// ── Stats counter ────────────────────────────────────────────
const parseVal = (raw: string) => {
  const m = raw.match(/^(\d+(?:\.\d+)?)(.*)$/)
  if (!m) return { n: 0, suf: '', dec: 0 }
  const dec = m[1].includes('.') ? m[1].split('.')[1].length : 0
  return { n: parseFloat(m[1]), suf: m[2], dec }
}

ScrollTrigger.batch('.stat-card', {
  start: 'top 80%',
  onEnter: (els) => {
    gsap.to(els, {
      opacity: 1, y: 0,
      duration: 0.7, stagger: 0.12, ease: 'power3.out',
      onStart() {
        els.forEach((el) => {
          const numEl = el.querySelector('.stat-num') as HTMLElement
          if (!numEl) return
          const raw = numEl.dataset.raw || ''
          const { n, suf, dec } = parseVal(raw)
          gsap.to({ val: 0 }, {
            val: n,
            duration: 1.8,
            ease: 'power2.out',
            onUpdate() {
              const cur: number = this.targets()[0].val
              numEl.textContent = (dec > 0 ? cur.toFixed(dec) : Math.floor(cur).toString()) + suf
            },
            onComplete() { numEl.textContent = raw },
          })
        })
      },
    })
  },
})

// ── Service panels ───────────────────────────────────────────
document.querySelectorAll<HTMLElement>('.s-service').forEach((panel) => {
  const img = panel.querySelector('.svc-img')
  const toAnimate = panel.querySelectorAll('.svc-title, .svc-sub, .svc-desc, .svc-features, .svc-link')

  const tl = gsap.timeline({
    scrollTrigger: {
      trigger: panel,
      start: 'top 60%',
      once: true,
    },
  })

  if (img) {
    tl.to(img, { scale: 1, duration: 1.2, ease: 'power2.out' }, 0)
  }
  tl.to(toAnimate, {
    opacity: 1, x: 0,
    stagger: 0.1, duration: 0.65, ease: 'power3.out',
  }, 0.15)
})

// ── Product cards ────────────────────────────────────────────
ScrollTrigger.batch('.prod-card', {
  start: 'top 85%',
  onEnter: (els) => {
    gsap.to(els, {
      opacity: 1, y: 0,
      stagger: 0.12, duration: 0.65, ease: 'power3.out',
    })
  },
})

// ── Case cards ───────────────────────────────────────────────
ScrollTrigger.batch('.case-card', {
  start: 'top 85%',
  onEnter: (els) => {
    gsap.to(els, {
      opacity: 1, y: 0,
      stagger: 0.08, duration: 0.6, ease: 'power3.out',
    })
  },
})

// ── Order Fulfillment steps ──────────────────────────────────
ScrollTrigger.create({
  trigger: '.s-fulfillment',
  start: 'top 75%',
  once: true,
  onEnter: () => {
    document.querySelector('.s-fulfillment')?.classList.add('is-visible')
    gsap.to('.fulfillment-step', {
      opacity: 1, y: 0,
      duration: 0.7, stagger: 0.1, ease: 'power3.out',
      delay: 0.1,
    })
  },
})

// ── CTA section ──────────────────────────────────────────────
gsap.to('.cta-inner', {
  opacity: 1, y: 0, duration: 0.9, ease: 'power3.out',
  scrollTrigger: { trigger: '.s-cta', start: 'top 70%', once: true },
})

// ── Case modal ────────────────────────────────────────────────
const caseData = JSON.parse(document.getElementById('case-data')!.textContent!)
const modal = document.getElementById('case-modal')!
const panel = modal.querySelector('.modal-panel') as HTMLElement

function openModal(id: string) {
  const d = caseData[id]
  if (!d) return

  // accent color + hero image
  panel.style.setProperty('--modal-accent', d.accent || '#2563EB')
  const heroImg = modal.querySelector('#modal-hero-img') as HTMLImageElement
  heroImg.src = d.image || ''
  heroImg.alt = d.fullName

  // header
  ;(modal.querySelector('#modal-category') as HTMLElement).textContent = d.category
  ;(modal.querySelector('#modal-title') as HTMLElement).textContent = d.fullName
  ;(modal.querySelector('#modal-desc') as HTMLElement).textContent = d.description

  // stats grid
  const statsEl = modal.querySelector('#modal-stats') as HTMLElement
  statsEl.innerHTML = d.stats.map((s: {label:string;value:string;unit:string}) => `
    <div class="modal-stat-card">
      <div class="modal-stat-val">${s.value}</div>
      ${s.unit ? `<div class="modal-stat-unit">${s.unit}</div>` : ''}
      <div class="modal-stat-label">${s.label}</div>
    </div>
  `).join('')

  ;(modal.querySelector('.modal-body') as HTMLElement).scrollTop = 0
  modal.hidden = false
  document.body.style.overflow = 'hidden'
  requestAnimationFrame(() => requestAnimationFrame(() => panel.classList.add('visible')))
}

function closeModal() {
  panel.classList.remove('visible')
  setTimeout(() => {
    modal.hidden = true
    document.body.style.overflow = ''
  }, 250)
}

document.querySelectorAll('.case-card').forEach((card) => {
  card.addEventListener('click', () => {
    const id = (card as HTMLElement).dataset.case
    if (id) openModal(id)
  })
})

modal.querySelector('.modal-close')!.addEventListener('click', closeModal)
modal.querySelector('.modal-backdrop')!.addEventListener('click', closeModal)
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape' && !modal.hidden) closeModal()
})
</script>
