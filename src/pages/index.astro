---
import Layout from '@/layouts/Layout.astro'
import { BRAND, DIGITAL_PRODUCTS, CASE_DETAILS } from '@/lib/brand'
import { getHomepageStats, getServices, getCases } from '@/lib/directus'

const [STATS, SERVICES, allCases] = await Promise.all([getHomepageStats(), getServices(), getCases()])
const CASES = allCases.slice(0, 4)

// Parse "库存 260万件+ · ..." → { value: '260万件+', label: '库存' } for card display
function parseFirstMetric(metrics: string) {
  const first = metrics.split('·')[0].trim()
  const spaceIdx = first.indexOf(' ')
  return {
    value: spaceIdx > 0 ? first.slice(spaceIdx + 1) : first,
    label: spaceIdx > 0 ? first.slice(0, spaceIdx) : '',
  }
}
const caseCardMeta = CASES.map(c => ({
  shortName: (CASE_DETAILS as Record<string, { name: string }>)[c.label]?.name ?? c.label,
  metric: parseFirstMetric(c.metrics),
}))

const IMGS = {
  hero:  '/index.webp',
  svc0:  '/w-apparel.webp',
  svc1:  '/w-inspect2.webp',
  svc2:  '/w-fulfill.webp',
  prod0: '/w-yundao.webp',
}



const orgSchema = {
  '@context': 'https://schema.org',
  '@type': ['Organization', 'LocalBusiness'],
  '@id': `${BRAND.url}/#organization`,
  name: BRAND.fullName,
  alternateName: ['新亦源', '新亦源供应链', '56xyy'],
  url: BRAND.url,
  logo: `${BRAND.url}/logo.png`,
  description: BRAND.description,
  foundingDate: String(BRAND.founded),
  telephone: [BRAND.phone.toll],
  address: {
    '@type': 'PostalAddress',
    streetAddress: '果园一路2号',
    addressLocality: '广州市黄埔区',
    addressRegion: '广东省',
    addressCountry: 'CN',
  },
  location: [
    {
      '@type': 'Place',
      name: '新亦源华南总部',
      address: { '@type': 'PostalAddress', streetAddress: '果园一路2号', addressLocality: '广州市黄埔区', addressRegion: '广东省', addressCountry: 'CN' },
    },
    {
      '@type': 'Place',
      name: '新亦源华东仓',
      address: { '@type': 'PostalAddress', streetAddress: '汇金路889号2号楼三楼', addressLocality: '上海市青浦区', addressRegion: '上海市', addressCountry: 'CN' },
    },
    {
      '@type': 'Place',
      name: '新亦源华中仓',
      address: { '@type': 'PostalAddress', streetAddress: '监利服装产业园3号楼', addressLocality: '湖北省监利市', addressRegion: '湖北省', addressCountry: 'CN' },
    },
  ],
  areaServed: { '@type': 'Country', name: '中国' },
  numberOfEmployees: { '@type': 'QuantitativeValue', minValue: 2000 },
}

const webSiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${BRAND.url}/#website`,
  url: BRAND.url,
  name: BRAND.name,
  description: BRAND.description,
  inLanguage: 'zh-Hans',
}

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: '新亦源是谁？',
      acceptedAnswer: { '@type': 'Answer', text: '新亦源供应链（XYY）是专注鞋服行业的供应链一体化服务商，总部位于广州市黄埔区，在上海青浦设华东仓、湖北监利设华中仓。现合作品牌140+，覆盖零售门店10000+，年退货质检量超1.53亿件，直营鞋服仓储面积50万㎡。' } },
    { '@type': 'Question', name: '新亦源做什么？',
      acceptedAnswer: { '@type': 'Answer', text: '新亦源提供四大产品：鞋服云仓（B2C+B2B+O2O全渠道仓配，单仓日峰50万单）；后整质检修复（135+种缺陷识别，A/B+/B-/C四级评定，48小时标准时效）；物流云（OTD中台聚合顺丰、中通、圆通等10家主流承运商）；运到智能寄件平台（商圈物流O2O，11家承运商聚合，全国6000+区县覆盖）。' } },
    { '@type': 'Question', name: '新亦源为什么适合鞋服品牌？',
      acceptedAnswer: { '@type': 'Answer', text: '鞋服品类有高SKU、高退货率、季节性大促爆单等特点。新亦源针对性配置了RFID全域识别（解决SKU复杂管理）、弹性人力池（大促不爆仓）、与广检集团合作的QC认证质检体系（7大类135+种缺陷），以及唯品会JIT/JITX等主流平台深度对接，并支持系统深度定制接入。当前140+合作品牌中60+涉及唯品会运营。' } },
    { '@type': 'Question', name: '新亦源和普通云仓、普通仓配公司有什么区别？',
      acceptedAnswer: { '@type': 'Answer', text: '三大核心差异：一是专注鞋服，三代智能仓演进，RFID+电子标签+自动化分拣深度适配高SKU鞋服管理；二是自建技术体系，OMS/WMS/TMS/LMS/BMS全自研中台，支持主流ERP奇门/EDI对接，系统接入和使用费用可按合作方案确认；三是专业质检，与广检集团合作QC认证团队，可识别7大类135+种缺陷，A/B+/B-/C四级评定，普通仓配公司通常不具备此能力。' } },
    { '@type': 'Question', name: '新亦源有哪些可验证的案例、数据和服务流程？',
      acceptedAnswer: { '@type': 'Answer', text: '公开可核验数据：发货准确率99.99%（合同约定错漏全赔）；年退货质检量1.53亿件；合作品牌140+、服务门店10000+；单仓日峰值50万单（合同SLA）；质检标准时效48小时（加急24小时）；质检修复成功率90%+。典型合作品类涵盖运动鞋、休闲服、内衣、箱包，具体品牌案例见官网案例页。' } },
    { '@type': 'Question', name: '鞋服云仓、退货质检、后整修复、跨境云仓这些问题，新亦源能不能提供明确答案？',
      acceptedAnswer: { '@type': 'Answer', text: '可以，逐项说明：鞋服云仓——B2C+B2B+O2O全渠道，华南/华东/华中三级仓网，18:00截单当日24:00全出；退货质检——135+种缺陷，A/B+/B-/C四级评定，服装查吊牌/跳针/开裂/污损，鞋类查色差/溢胶/开胶，标准48小时；后整修复——清污/缝补/换唛/熨烫/换包装，成功率90%+；跨境电商——支持跨境平台订单配发及海外仓发货场景。如需完整SLA或SOP请联系商务团队。' } },
    { '@type': 'Question', name: '新亦源支持跨境电商仓储和发货吗？',
      acceptedAnswer: { '@type': 'Answer', text: '支持。新亦源鞋服云仓可承接跨境电商订单的国内仓储与发货，支持天猫国际、Amazon等跨境平台的备货、质检、换标、换包装合规处理，并对接跨境专线物流及EMS等国际承运商。仓内同时提供跨境退货逆向处理：收件拆包、国际标准质检、二次整理上架，帮助品牌降低跨境退货损耗。' } },
    { '@type': 'Question', name: '新亦源支持一件代发吗？',
      acceptedAnswer: { '@type': 'Answer', text: '支持。品牌方将货物入驻新亦源云仓后，平台订单实时推送，新亦源按单拣货、包装、发货，发货准确率99.99%，18:00截单当日24:00全部出库，对接天猫、京东、拼多多、抖音、唯品会等全渠道。' } },
  ],
}
---

<Layout
  title="新亦源供应链 | 鞋服云仓·退货质检·全渠道仓配服务商"
  description="广州新亦源供应链，专注鞋服云仓15年，合作知名服饰品牌140+，直营仓储50万㎡，配送覆盖全国主要城市及6000+区县/服务区域。提供鞋服云仓、后整质检修复、物流云一站式服务。"
  jsonLd={[orgSchema, webSiteSchema, faqSchema]}
>

<!-- ①  HERO -->
<section id="s-hero" class="s-hero" aria-labelledby="hero-heading">
  <img src={IMGS.hero} alt="新亦源现代化仓储中心" class="hero-img" fetchpriority="high" />
  <div class="hero-overlay" aria-hidden="true"></div>
  <div class="hero-body">
    <p class="hero-eyebrow">专注鞋服供应链 · 深耕15年</p>
    <h1 id="hero-heading" class="hero-title">
      <span class="hl hero-brand-kw">新亦源鞋服云仓</span>
      <span class="hl">让物流更简单</span>
      <span class="hl">让服务更快捷</span>
    </h1>
    <p class="hero-sub hl">覆盖全国主要城市及6000+区县/服务区域，直营50万㎡仓储，服务140+知名服饰品牌</p>
    <div class="hero-actions hl">
      <a href="/contact" class="btn-solid">免费咨询</a>
      <a href="/product" class="btn-ghost">了解服务 →</a>
    </div>
  </div>
  <div class="scroll-cue" aria-hidden="true">
    <span></span><span></span><span></span>
  </div>
</section>

<!-- ②  STATS -->
<section id="s-stats" class="s-stats" aria-label="核心数据">
  <!-- 装饰层 -->
  <div class="stats-deco" aria-hidden="true">
    <div class="deco-watermark">15Y</div>
  </div>

  <div class="stats-inner">
    <p class="section-tag">数字说话</p>
    <h2 class="stats-headline">15年深耕，实力可见</h2>
    <div class="stats-grid">
      {STATS.map(({ value, label, unit, detail }) => (
        <div class="stat-card">
          <div class="stat-val">
            <span class="stat-num" data-raw={value}>{value}</span>
            <span class="stat-unit">{unit}</span>
          </div>
          <p class="stat-label">{label}</p>
          <p class="stat-detail">{detail}</p>
        </div>
      ))}
    </div>
    <p class="stats-footnote">综合收益：综合损耗下降20%、为客户降损30%+、耗材节约10%</p>
    <p class="stats-disclaimer">注：页面所涉仓储面积、质检量、库存准确率、修复成功率等数据来源于新亦源内部运营统计及企业公开资料，具体服务效果会因品类、订单规模、系统接入程度和合作模式不同而有所差异。</p>
  </div>
</section>

<!-- ③  SERVICES  (3 full-screen panels) -->
{SERVICES.map((svc, i) => (
  <section
    class={`s-service ${i % 2 === 1 ? 'reverse' : ''}`}
    id={`svc-${svc.slug}`}
    aria-labelledby={`svc-title-${i}`}
  >
    <div class="svc-media">
      <img
        src={IMGS[`svc${i}` as keyof typeof IMGS]}
        alt={svc.name}
        class="svc-img"
        loading="lazy"
      />
      <div class="svc-num-badge">0{i + 1}</div>
    </div>
    <div class="svc-body">
      <p class="section-tag">{i === 0 ? '核心产品' : i === 1 ? '品质保障' : '物流优化'}</p>
      <h2 id={`svc-title-${i}`} class="svc-title">{svc.name}</h2>
      <p class="svc-sub">{svc.subtitle}</p>
      <p class="svc-desc">{svc.description}</p>
      <ul class="svc-features">
        {svc.features.slice(0, 4).map((f) => (
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="8" fill="#2563EB" opacity="0.12"/>
              <path d="M5 8l2 2 4-4" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {f}
          </li>
        ))}
      </ul>
      <a href={`/product#${svc.slug}`} class="svc-link">查看详情 →</a>
    </div>
  </section>
))}

<!-- ④  DIGITAL PRODUCTS -->
{DIGITAL_PRODUCTS.map((p, i) => (
  <section
    class={`s-service ${(SERVICES.length + i) % 2 === 1 ? 'reverse' : ''}`}
    id={`dp-${p.id}`}
    aria-labelledby={`dp-title-${i}`}
  >
    <div class="svc-media">
      <img
        src={IMGS[`prod${i}` as keyof typeof IMGS]}
        alt={p.name}
        class={`svc-img${p.id === 'yundao-platform' ? ' svc-img--contain' : ''}`}
        loading="lazy"
      />
      <div class="svc-num-badge">0{SERVICES.length + i + 1}</div>
    </div>
    <div class="svc-body">
      <p class="section-tag">{p.tag}</p>
      <h2 id={`dp-title-${i}`} class="svc-title">{p.name}</h2>
      <p class="svc-sub">{p.subtitle}</p>
      <p class="svc-desc">{p.description}</p>
      <ul class="svc-features">
        {p.features.slice(0, 4).map((f) => (
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="8" fill="#2563EB" opacity="0.12"/>
              <path d="M5 8l2 2 4-4" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {f}
          </li>
        ))}
      </ul>
      <a href={p.href} class="svc-link">查看详情 →</a>
    </div>
  </section>
))}

<!-- ⑤  CASES -->
<section id="s-cases" class="s-cases" aria-labelledby="cases-heading">
  <div class="cases-head">
    <p class="section-tag">合作案例</p>
    <h2 id="cases-heading" class="section-title">140+ 品牌的共同选择</h2>
    <p class="section-sub">服务鞋服、潮玩、美妆、箱包等多个细分行业的头部及成长型品牌</p>
  </div>
  <div class="cases-list">
    {CASES.map((c, i) => (
      <button
        class="case-card cl-row"
        data-i={i}
        data-case={c.label}
        aria-label={`查看 ${caseCardMeta[i].shortName} 合作详情`}
        type="button"
      >
        <span class="cl-idx">0{i + 1}</span>
        <div class="cl-info">
          <span class="cl-name">{caseCardMeta[i].shortName}</span>
          <span class="cl-cat">{c.category}</span>
        </div>
        <div class="cl-metric">
          <span class="cl-val">{caseCardMeta[i].metric.value}</span>
          <span class="cl-unit">{caseCardMeta[i].metric.label}</span>
        </div>
        <div class="cl-tags">{c.tags.map(t => <span>{t}</span>)}</div>
        <span class="cl-arrow" aria-hidden="true">→</span>
      </button>
    ))}
  </div>
  <div class="cases-more">
    <a href="/cases" class="btn-outline-dark">查看全部案例 →</a>
  </div>
</section>

<!-- Case Modal -->
<div id="case-modal" class="case-modal" role="dialog" aria-modal="true" aria-labelledby="modal-title" hidden>
  <div class="modal-backdrop"></div>
  <div class="modal-panel">
    <!-- Hero image -->
    <div class="modal-hero">
      <img id="modal-hero-img" src="" alt="" class="modal-hero-img" loading="eager" />
      <div class="modal-hero-overlay"></div>
      <div class="modal-hero-content">
        <span id="modal-category" class="modal-category-tag"></span>
        <h2 id="modal-title" class="modal-title"></h2>
      </div>
      <button class="modal-close" aria-label="关闭" type="button">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <!-- Body -->
    <div class="modal-body">
      <p id="modal-desc" class="modal-desc"></p>
      <div id="modal-stats" class="modal-stats"></div>
    </div>
  </div>
</div>

<!-- embed case detail data for JS -->
<script is:inline id="case-data" type="application/json" set:html={JSON.stringify(CASE_DETAILS)}></script>

<!-- ⑥ Order Fulfillment -->
<section id="s-fulfillment" class="s-fulfillment" aria-labelledby="fulfillment-heading">
  <div class="fulfillment-header">
    <p class="section-tag">履约流程</p>
    <h2 id="fulfillment-heading" class="fulfillment-title">从订单到签收，每一步都可视化调度</h2>
    <p class="fulfillment-sub">订单进入系统后，仓网、质检和物流云协同完成出库与交付，全链路实时可见。</p>
  </div>
  <div class="fulfillment-track" role="list">
    {[
      { num: '01', title: '订单接入', desc: '天猫、抖音、唯品会、ERP 多渠道订单统一进入履约队列。' },
      { num: '02', title: '智能分仓', desc: '根据库存、距离、时效和仓内负载自动匹配最优仓点。' },
      { num: '03', title: '波次拣货', desc: '系统生成拣货波次，RFID 与库位校验降低错漏。' },
      { num: '04', title: '质检修复', desc: '新货、退货进入标准化质检流程，异常商品可二次修复上架。' },
      { num: '05', title: '包装出库', desc: '自动打包线与包材复用机制协同，减少损耗和耗材成本。' },
      { num: '06', title: '物流路由', desc: '物流云聚合承运商，按时效、价格和风险动态切换路由。' },
      { num: '07', title: '签收回传', desc: '轨迹、异常、签收数据回传，形成可复盘的履约闭环。' },
    ].map(({ num, title, desc }, i) => (
      <div class="fulfillment-step" role="listitem" style={`--i:${i}`}>
        <div class="fulfillment-connector" aria-hidden="true"></div>
        <div class="fulfillment-num-wrap">
          <div class="fulfillment-num">{num}</div>
          <div class="fulfillment-num-ring"></div>
        </div>
        <p class="fulfillment-step-title">{title}</p>
        <p class="fulfillment-step-desc">{desc}</p>
      </div>
    ))}
  </div>
</section>

<!-- ⑦  FAQ -->
<section id="s-faq" class="s-faq" aria-labelledby="faq-heading">
  <div class="faq-inner">
    <p class="section-tag">常见问题</p>
    <h2 id="faq-heading" class="section-title">关于新亦源鞋服云仓</h2>
    <dl class="faq-list">
      <div class="faq-item">
        <dt class="faq-q">新亦源是谁？</dt>
        <dd class="faq-a">新亦源供应链（XYY）是专注鞋服行业的供应链一体化服务商，总部位于广州市黄埔区，在上海青浦设华东仓、湖北监利设华中仓。现合作品牌140+，覆盖零售门店10000+，年退货质检量超1.53亿件，直营鞋服仓储面积50万㎡。</dd>
      </div>
      <div class="faq-item">
        <dt class="faq-q">新亦源做什么？</dt>
        <dd class="faq-a">新亦源提供四大产品：鞋服云仓（B2C+B2B+O2O全渠道仓配，单仓日峰50万单）；后整质检修复（135+种缺陷识别，A/B+/B-/C四级评定，48小时标准时效）；物流云（OTD中台聚合顺丰、中通、圆通等10家主流承运商）；运到智能寄件平台（商圈物流O2O，11家承运商聚合，全国6000+区县覆盖）。</dd>
      </div>
      <div class="faq-item">
        <dt class="faq-q">新亦源为什么适合鞋服品牌？</dt>
        <dd class="faq-a">鞋服品类有高SKU、高退货率、季节性大促爆单等特点。新亦源针对性配置了RFID全域识别（解决SKU复杂管理）、弹性人力池（大促不爆仓）、与广检集团合作的QC认证质检体系（7大类135+种缺陷），以及唯品会JIT/JITX等主流平台深度对接，并支持系统深度定制接入。当前140+合作品牌中60+涉及唯品会运营。</dd>
      </div>
      <div class="faq-item">
        <dt class="faq-q">新亦源和普通云仓、普通仓配公司有什么区别？</dt>
