---
import ServiceLanding from '@/layouts/ServiceLanding.astro'

const COMPARE_ROWS = [
  {
    item: '模式定位',
    jit: '按需供货，活动前备货到仓，活动开始后按单快速发货，降低库存积压',
    jitx: 'JIT 升级版，极速供应链，适合爆款和高频复购商品，响应要求更严格',
  },
  {
    item: '发货时效要求',
    jit: '平日 48 小时内，活动期间 24 小时内',
    jitx: '平日 24 小时内，活动期间 12 小时内',
  },
  {
    item: '库存同步要求',
    jit: '实时库存同步，订单下发后自动波次拣货',
    jitx: '实时同步 + 提前预警机制，库存低于阈值自动提醒',
  },
  {
    item: '系统对接要求',
    jit: '标准奇门 / EDI 接口，WMS 与唯品会平台打通',
    jitx: '同 JIT，另需满足 JITX 专属接口协议与数据反馈频率',
  },
  {
    item: '主要扣分风险点',
    jit: '延时发货 · 短发漏发 · 包装质量不达标',
    jitx: '时间窗口违规 · 数量精确性误差 · 系统响应超时 · 标签错误',
  },
  {
    item: '新亦源应对方案',
    jit: '18:00 截单当日 24:00 全出 · 99.99% 准确率 · SLA 合同保障',
    jitx: '肇庆唯品会物流园内直发 · 极速产能响应 · 大促专项排班',
  },
]

const RISK_ITEMS = [
  { risk: '延时发货', level: '高', tip: '仓配服务商未在活动时效内完成出库，直接触发唯品会平台扣分' },
  { risk: '短发 / 漏发', level: '高', tip: '实际出库数量与订单不符，影响品牌评级和平台信任分' },
  { risk: '包装不合规', level: '中', tip: '唯品会对包装规格、面单格式有严格要求，不合规将被退件' },
  { risk: '系统响应超时', level: '中', tip: 'JITX 对 WMS 与平台系统的响应频率有要求，延迟将触发预警' },
]
---

<ServiceLanding
  title="唯品会JIT/JITX仓配服务商 — 60+品牌专属经验，肇庆唯品会物流园内 | 新亦源"
  description="新亦源是唯品会JIT/JITX深度合作仓配服务商，合作品牌140+中60+涉及唯品会运营，肇庆四会仓位于唯品会物流园内，JIT+JITX双模式对接，18:00截单当日24:00全出。"
  slug="weipinhui-jit-jitx"
  breadcrumbLabel="唯品会JIT/JITX"
  eyebrow="唯品会JIT/JITX · 专业仓配对接服务商"
  h1="唯品会JIT/JITX仓配"
  h1sub="60+品牌专属运营经验，肇庆唯品会物流园内直发"
  heroDesc="新亦源是唯品会深度合作仓配服务商，合作品牌140+中60+涉及唯品会运营，肇庆四会仓位于唯品会物流园内，JIT/JITX标准化对接经验丰富，SLA合同保障。"
  imgSrc="/w-fulfill.webp"
  imgAlt="唯品会JIT/JITX仓配 — 专业快速发货"
  stats={[
    { stat: '60+', label: '涉及唯品会运营的合作品牌', sub: '占合作品牌总数43%+' },
    { stat: '仓内', label: '唯品会物流园', sub: '肇庆四会专属园区' },
    { stat: 'JIT+JITX', label: '双模式支持', sub: '完整对接标准' },
    { stat: '18:00截单', label: '当日全出SLA', sub: '合同保障' },
  ]}
  contentDesc="唯品会JIT（Just-In-Time）和JITX模式对鞋服品牌的仓配服务商有严格的系统、时效和质量要求。新亦源在肇庆四会唯品会物流园内设有专属仓，具备JIT和JITX双模式对接能力，OMS/WMS系统与唯品会平台深度打通，支持库存同步、订单推送、发货回传的全流程自动化。合作140+品牌中60+涉及唯品会运营，积累了丰富的唯品会JIT/JITX操作经验和大促应急预案。"
  featuresLabel="核心能力"
  features={[
    { title: '唯品会园区内直发', desc: '肇庆四会仓位于唯品会物流园内，减少转运环节，JIT订单响应速度更快，降低因转运造成的时效风险。' },
    { title: 'JIT/JITX双模式', desc: '同时支持JIT（按需生产发货）和JITX（极速供应链）两种唯品会模式，根据品牌和商品类型灵活切换。' },
    { title: '系统深度对接', desc: '自研WMS/OMS与唯品会ERP、订单系统深度打通，库存同步实时精准，订单处理自动化，无需人工二次操作。' },
    { title: 'SLA合同保障', desc: '18:00截单当日24:00全出，发货准确率99.99%，错漏全赔，与唯品会平台时效考核指标对齐。' },
    { title: '退货质检联动', desc: '唯品会退货回流直接在仓内完成质检、分级、修复、二次上架，缩短退货处理周期，快速补充JIT可售库存。' },
    { title: '大促专项保障', desc: '唯品会特卖节等大促期间，启动弹性人力机制，提前预排班，保障大促发货时效稳定，不出现SLA违约。' },
  ]}
  faqs={[
    {
      q: '唯品会JIT和JITX模式有什么区别？',
      a: 'JIT（Just-In-Time）是唯品会的按需采购模式，品牌按活动计划备货，活动开始后按单快速发货，降低积压；JITX是JIT的升级版，要求更快速的备货响应和更严格的发货时效，适合爆款和高频复购商品。两种模式都要求仓配服务商具备实时库存同步和极速发货能力，新亦源均支持。',
    },
    {
      q: '新亦源唯品会仓配有什么核心优势？',
      a: '三大核心优势：①肇庆四会仓在唯品会物流园内，物流节点最近，时效优势明显；②合作品牌60+涉及唯品会运营，有大量真实案例和应急预案；③WMS与唯品会系统深度对接，库存+订单+发货全链路自动化，人工干预少、出错率低。',
    },
    {
      q: '新亦源肇庆唯品会物流园仓规模如何？',
      a: '肇庆四会仓：总园区面积100,000㎡，新亦源使用面积50,000㎡；12米超高仓，多条自动打包线，快递资源发达（位于物流园内，多家快递公司驻仓）。',
    },
    {
      q: 'JIT模式对发货时效有什么要求，新亦源能达到吗？',
      a: '唯品会JIT/JITX通常要求：平日48小时内发货，活动期间24小时内发货。新亦源SLA承诺：18:00截单当日24:00全出（平日），大促期间额外配置人力保障。历史合作期间未出现因仓配时效问题导致的唯品会平台降分记录。',
    },
    {
      q: '开始唯品会JIT/JITX合作需要什么条件？',
      a: '通常需要：①商品已在唯品会平台上线并开通JIT/JITX资格；②与新亦源签署仓配服务协议（含SLA条款）；③完成系统对接测试（通常1-2周）；④首批货物入库验收。新亦源提供全程对接支持，商务团队协助办理平台对接手续。',
    },
  ]}
>
  <section slot="unique" class="py-14 bg-white border-b border-gray-100" aria-labelledby="jit-compare-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="jit-compare-heading" class="text-xl font-black text-navy-800 mb-1 text-center">JIT vs JITX — 要求对比与扣分风险</h2>
      <p class="text-xs text-gray-400 text-center mb-8">了解两种模式的核心差异，规避仓配侧常见扣分风险</p>

      <!-- 对比表 -->
      <div class="overflow-x-auto rounded-xl border border-gray-200 mb-8">
        <table class="w-full text-sm text-left">
          <thead>
            <tr class="bg-navy-800 text-white">
              <th class="px-5 py-3.5 font-bold text-xs tracking-wider w-36">对比项</th>
              <th class="px-5 py-3.5 font-bold text-xs tracking-wider">
                <span class="inline-block px-2 py-0.5 rounded bg-brand-orange/20 text-brand-orange mr-1">JIT</span>
                按需供货
              </th>
              <th class="px-5 py-3.5 font-bold text-xs tracking-wider">
                <span class="inline-block px-2 py-0.5 rounded bg-white/20 mr-1">JITX</span>
                极速供应链
              </th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            {COMPARE_ROWS.map(({ item, jit, jitx }) => (
              <tr class="hover:bg-orange-50/20 transition-colors">
                <td class="px-5 py-4 font-bold text-navy-700 text-xs align-top whitespace-nowrap">{item}</td>
                <td class="px-5 py-4 text-gray-600 text-xs leading-relaxed align-top">{jit}</td>
                <td class="px-5 py-4 text-gray-600 text-xs leading-relaxed align-top">{jitx}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- 扣分风险提示 -->
      <h3 class="text-sm font-bold text-navy-800 mb-3">仓配侧常见扣分风险提示</h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
        {RISK_ITEMS.map(({ risk, level, tip }) => (
          <div class={`rounded-lg border p-4 ${level === '高' ? 'border-red-200 bg-red-50' : 'border-yellow-200 bg-yellow-50'}`}>
            <div class="flex items-center gap-2 mb-2">
              <span class={`text-[10px] font-black px-1.5 py-0.5 rounded ${level === '高' ? 'bg-red-500 text-white' : 'bg-yellow-400 text-white'}`}>{level}风险</span>
              <span class="text-sm font-bold text-navy-800">{risk}</span>
            </div>
            <p class="text-xs text-gray-500 leading-snug">{tip}</p>
          </div>
        ))}
      </div>
      <p class="text-xs text-gray-400 mt-4">新亦源历史合作期间未出现因仓配时效问题导致的唯品会平台降分记录</p>
    </div>
  </section>
</ServiceLanding>
