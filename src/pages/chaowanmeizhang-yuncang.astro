---
import ServiceLanding from '@/layouts/ServiceLanding.astro'

const CATEGORY_CARDS = [
  {
    name: '潮玩 / 盲盒',
    color: 'border-purple-200',
    dotColor: 'bg-purple-400',
    storage: '恒温恒湿库区，独立货架',
    inspect: '外包装完整性、配件齐全、限定款封签',
    pack: '气泡膜+内衬纸箱，防震防压',
    note: '限定款需摄像取证，支持单品溯源',
  },
  {
    name: '美妆 / 护肤品',
    color: 'border-pink-200',
    dotColor: 'bg-pink-400',
    storage: '阴凉避光仓区，远离热源',
    inspect: '保质期核验、封口完整、外观无破损',
    pack: '气泡膜+防潮袋，液体防漏处理',
    note: '临期品预警机制，保质期管控到批次',
  },
  {
    name: '箱包 / 皮具',
    color: 'border-amber-200',
    dotColor: 'bg-amber-400',
    storage: '吊挂或平铺存放，防挤压变形',
    inspect: '五金件、拉链、缝线、皮面外观',
    pack: '防尘袋+填充纸，防止皮面压痕',
    note: '高值款单独区域存放，出入库双人复核',
  },
  {
    name: '鞋服（扩品类）',
    color: 'border-blue-200',
    dotColor: 'bg-blue-400',
    storage: '标准仓区，RFID上架管理',
    inspect: '外观质检+AQL抽检，135+缺陷识别',
    pack: '标准快递箱或吊挂箱，按品牌要求',
    note: '与潮玩/美妆共仓，一套系统统一管理',
  },
]
---

<ServiceLanding
  title="潮玩美妆仓储服务 — 潮玩盲盒、美妆护肤、箱包仓配一体 | 新亦源"
  description="新亦源潮玩美妆仓储，覆盖潮玩盲盒、美妆护肤、箱包皮具等细分品类，恒温恒湿存储、保质期管控、限定款摄像取证、防震包装，多品类共仓统一管理。"
  slug="chaowanmeizhang-yuncang"
  breadcrumbLabel="潮玩美妆仓储"
  eyebrow="潮玩美妆仓储 · 多品类精细化仓配管理"
  h1="潮玩美妆仓储"
  h1sub="潮玩盲盒、美妆护肤、箱包皮具精细仓配"
  heroDesc="新亦源潮玩美妆仓储专为潮玩、美妆、箱包等高值精细品类设计，提供恒温恒湿存储、保质期批次管控、限定款取证入库、防震防压包装等专业仓配服务，与鞋服共仓统一管理。"
  imgSrc="/w-apparel.webp"
  imgAlt="潮玩美妆仓储 — 精细品类仓配管理"
  stats={[
    { stat: '4大品类', label: '潮玩/美妆/箱包/鞋服', sub: '多品类共仓统一管理' },
    { stat: '批次管控', label: '保质期精准追踪', sub: '临期品自动预警' },
    { stat: '1080P', label: '摄像取证', sub: '限定款拆包全程录像' },
    { stat: '0元', label: '系统接入费', sub: '多平台对接免费' },
  ]}
  contentDesc="潮玩、美妆、箱包等品类与鞋服在仓储和质检要求上有显著差异：潮玩盲盒需要防震防压、限定款需要摄像取证；美妆护肤需要阴凉避光存储、保质期批次管控；箱包皮具需要防挤压变形、五金件和皮面细节质检。新亦源在主营鞋服云仓的基础上，已成功拓展至潮玩、美妆、箱包等细分品类，为合作品牌提供多品类共仓解决方案，一套WMS系统统一管理不同品类库存，降低多仓运营成本。合作品牌包括潮玩、美妆、箱包等140+品牌中的非鞋服品类客户。"
  featuresLabel="潮玩美妆核心仓配能力"
  features={[
    { title: '恒温恒湿存储区', desc: '潮玩、美妆等对温湿度敏感品类使用独立的恒温恒湿库区，全年温湿度监控，防止因环境变化导致商品受损。' },
    { title: '保质期批次管控', desc: '美妆护肤品按生产批次和保质期入库管理，WMS系统自动追踪每批次剩余保质期，临期品（90天/60天/30天）自动预警，确保先进先出。' },
    { title: '限定款取证入库', desc: '潮玩限定款、联名款入库时启动1080P摄像全程取证，记录拆箱、清点、上架全流程，作为电商争议凭证，保护品牌和买家权益。' },
    { title: '精细防震包装', desc: '根据品类特性定制包装方案：潮玩气泡膜+硬纸内衬防压；美妆液体类防漏包装+防潮袋；箱包防尘袋+填充纸防变形，减少物流损耗。' },
    { title: '多品类共仓管理', desc: '潮玩、美妆、箱包可与鞋服品类在同一仓库内分区管理，同一WMS统一库存视图，同一OMS接收各品类订单，降低品牌多仓管理成本。' },
    { title: '高值品双人复核', desc: '限定款潮玩、高值美妆、奢侈箱包出入库时双人复核，独立存放区加锁管理，异常操作摄像存档，全程链路可溯源。' },
  ]}
  faqs={[
    {
      q: '新亦源可以同时仓储潮玩和鞋服吗？',
      a: '可以。新亦源采用分区共仓模式：潮玩/美妆/箱包与鞋服在同一仓库内各自独立分区存放，互不混仓，但共用一套WMS系统统一管理库存。品牌方在OMS平台上可同时看到不同品类的库存，统一对账，无需分别管理多个仓库账号。',
    },
    {
      q: '美妆品保质期管控是怎么做的？',
      a: '入库时扫码录入生产日期和保质期，WMS自动计算剩余保质期并关联SKU批次。设置三级预警：①90天预警（提醒品牌加大促销力度）；②60天预警（优先拣货出库，加速清货）；③30天预警（暂停该批次出库，等候品牌指令）。发货时严格执行先进先出（FIFO），保证消费者收到商品有足够保质期。',
    },
    {
      q: '潮玩限定款怎么防止入库时就出现破损纠纷？',
      a: '限定款/联名款入库全流程1080P摄像录像：①收货时整件箱外观拍照；②拆箱过程录像；③逐件清点核对录像，记录每件商品序列号或外包装编号；④上架前拍照存档。如后续发生商品状态争议，可调取对应入库视频作为凭证。',
    },
    {
      q: '箱包皮具如何防止仓储过程中变形？',
      a: '包括：①入库时每件箱包装入品牌专属防尘袋，充填保形纸；②上架存放方式按品牌要求（站立/平铺/吊挂），避免堆压；③皮革类定期通风检查；④出库打包时重新充填保形纸+气泡膜缠绕，整箱加固胶带。全流程操作规范由品牌方审核确认后录入标准作业卡。',
    },
    {
      q: '潮玩美妆品类的收费方式和鞋服一样吗？',
      a: '基本收费结构相同（仓储费+操作费），但因精细操作项（取证摄像、批次管控、防震包装）有单独加收项。具体定价根据品类、SKU数量、月均吞吐量和特殊操作需求定制，建议联系商务团队评估，通常首单可免费试运营。',
    },
  ]}
>
  <section slot="unique" class="py-14 bg-gray-50 border-b border-gray-100" aria-labelledby="category-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="category-heading" class="text-xl font-black text-navy-800 mb-1 text-center">各品类仓储质检标准</h2>
      <p class="text-xs text-gray-400 text-center mb-8">不同品类有不同的存储、质检和包装要求，新亦源按品类定制作业标准</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {CATEGORY_CARDS.map(({ name, color, dotColor, storage, inspect, pack, note }) => (
          <div class={`bg-white rounded-xl border-2 ${color} p-5 flex flex-col gap-3`}>
            <div class="flex items-center gap-2">
              <span class={`w-2.5 h-2.5 rounded-full flex-shrink-0 ${dotColor}`}></span>
              <h3 class="font-black text-navy-800 text-sm">{name}</h3>
            </div>
            <div class="space-y-2.5 text-xs">
              <div>
                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-0.5">存储方式</p>
                <p class="text-gray-600 leading-snug">{storage}</p>
              </div>
              <div>
                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-0.5">质检重点</p>
                <p class="text-gray-600 leading-snug">{inspect}</p>
              </div>
              <div>
                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-0.5">包装规范</p>
                <p class="text-gray-600 leading-snug">{pack}</p>
              </div>
            </div>
            <div class="pt-2 border-t border-gray-100">
              <p class="text-[10px] text-brand-orange font-medium leading-snug">{note}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</ServiceLanding>
