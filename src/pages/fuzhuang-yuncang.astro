---
import ServiceLanding from '@/layouts/ServiceLanding.astro'

const CATEGORY_TABLE = [
  {
    cat: '女装 / 快时尚',
    storage: '挂装区 + 叠装分区，连衣裙/风衣走挂装，T恤/卫衣走叠装',
    inspect: '跳针、污损、色差、吊牌完整、尺码一致性',
    packing: '防尘袋 / OPP袋，挂装出库配挂钩',
    note: '高SKU 精细管理，换季清点，滞销品定期盘库',
  },
  {
    cat: '男装 / 商务装',
    storage: '折叠标准化存储，西装/衬衫配独立包装盒区',
    inspect: '版型平整、缝线做工、纽扣/拉链完好',
    packing: '包装纸 + 平铺折叠，高价位商品配硬盒',
    note: '尺码颜色分区，批次管理，商务服装防压痕',
  },
  {
    cat: '内衣 / 袜类',
    storage: '小件密集型货架，单件独立格位',
    inspect: '尺码精确（S/M/L不混淆）、包装完整、无异味',
    packing: '独立封装/透明袋，混装组合需逐件核对',
    note: '单件条码绑定，防混淆，私密品类专区存储',
  },
  {
    cat: '运动服 / 鞋类',
    storage: '运动服走挂装；鞋类独立鞋盒区，配防变形填充',
    inspect: '功能标签合规、配件齐全，鞋类查大小脚/色差/开胶',
    packing: '运动服挂装发货 + 填充纸，鞋盒原装保护',
    note: '鞋类专项：大小脚检查 + 溢胶/开胶/脏污三检',
  },
]
---

<ServiceLanding
  title="服装云仓服务商 — 全渠道仓配+退货质检+深加工，专注鞋服行业 | 新亦源"
  description="新亦源服装云仓，针对女装/男装/内衣/运动服深度优化，RFID智能识别解决高SKU管理难题，弹性人力池保障大促不延迟，B2C+B2B+O2O多渠道发货。"
  slug="fuzhuang-yuncang"
  breadcrumbLabel="服装云仓"
  eyebrow="服装云仓 · 全渠道仓配一体化"
  h1="服装云仓"
  h1sub="T恤/卫衣/内衣/运动服 全品类仓储"
  heroDesc="新亦源服装云仓深度适配女装、男装、内衣、袜类、运动服等品类，RFID全域识别解决高SKU管理难题，弹性产能保障大促不延迟，服务品牌140+。"
  imgSrc="/w-apparel.webp"
  imgAlt="服装云仓 — 专业服装仓储管理"
  stats={[
    { stat: '99.99%', label: '库存准确率', sub: 'RFID+系统双重校验' },
    { stat: '50万单/日', label: '单仓峰值', sub: '大促弹性扩产' },
    { stat: '50万㎡', label: '直营仓储面积', sub: '华南/华东/华中布局' },
    { stat: '7大类', label: '质检缺陷覆盖', sub: '135+种可识别缺陷' },
  ]}
  contentDesc="服装品类具有高SKU、季节性、尺码/颜色组合复杂的特点，普通仓库难以高效管理。新亦源服装云仓以深度定制WMS为核心，内置RFID全域识别、电子标签拣货与自动化分拣，专项解决服装高SKU管理难题。T恤、卫衣、内衣、袜类、打底衫等基础品类，以及女装、男装、运动服等高品质品类均有大量合作案例，年服务品牌覆盖快时尚、高端设计师品牌、内衣、运动鞋服、跨境等多个细分类目。"
  featuresLabel="核心能力"
  features={[
    { title: '高SKU精准管理', desc: 'RFID+电子标签全域识别，支持序列号/货号/条码多维管理，彻底解决服装SKU过万时的拣货混乱和库存误差问题。' },
    { title: '全渠道库存同步', desc: 'B2C+B2B+O2O实时库存同步，支持天猫/京东/拼多多/抖音/唯品会多平台，库存准确率99.99%+，避免超卖。' },
    { title: '退货质检一体化', desc: '正向仓配+逆向退货质检在同一系统闭环，退货48小时内完成质检评级并二次上架，最大化服装商品价值。' },
    { title: '挂装+叠装存储', desc: '连衣裙/风衣/西装等挂装品类配备立体挂装区；T恤/卫衣等叠装品类配备恒温仓，防霉防蛀。' },
    { title: '大促弹性保障', desc: '人力弹性池+小时级调配，历史最大单日处理50万件，618/双11从未出现SLA违约。' },
    { title: '深加工服务', desc: '支持成衣印花/印秀、车标烫标、辅料定制、换唛换标等深加工，配合一件代发，省去工厂对接中间层。' },
  ]}
  faqs={[
    {
      q: '服装云仓和普通电商云仓有什么区别？',
      a: '核心区别在于专业化深度。服装云仓针对服装品类三大痛点：①高SKU——新亦源WMS支持RFID+序列号+货号多维索引，万级SKU管理无误差；②高退货率——配套退货质检+修复+二次上架全链路，不只是仓储；③季节性大促——弹性人力池+多仓协同，避免爆仓延迟。普通云仓不具备上述专项能力。',
    },
    {
      q: '新亦源服装云仓合作过哪些品类？',
      a: '已服务品类覆盖：快时尚女装（UR）、高端设计师女装（MAXRIENY）、内衣基础品类（幸棉）、运动鞋服（头部国际运动品牌）、跨境快时尚（Urbanic）等140+个品牌。B2C/B2B/O2O全渠道均有规模化运营案例。',
    },
    {
      q: '服装云仓如何解决尺码颜色混淆问题？',
      a: '采用RFID全域识别+电子标签双重防错体系：①入库时每件商品绑定RFID/条码，系统记录颜色/尺码/批次；②拣货时电子标签亮灯引导，RFID核验防止拣错；③出库扫描复核，错漏率<0.01%。对于错漏发货，合同承诺全赔。',
    },
    {
      q: '服装退货的质检和修复服务怎么算费用？',
      a: '退货质检和修复是独立计费服务（不含在仓储费中）。计费方式：质检按件数，修复按修复类型（清污/缝补/换配件等）。新客可申请样品试质检，确认质检标准和报价后再正式合作。',
    },
    {
      q: '新亦源服装云仓有哪些仓库地址？',
      a: '华南总部：广州黄埔果园一路2号+广州番禺石楼镇+东莞常平/桥头/朗州（三仓）+肇庆四会唯品会物流园；华东：上海青浦汇金路889号；华中：湖北监利服装产业园。华南仓区合计超30万㎡。',
    },
  ]}
>
  <section slot="unique" class="py-14 bg-gray-50 border-b border-gray-100" aria-labelledby="category-table-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="category-table-heading" class="text-xl font-black text-navy-800 mb-1 text-center">各品类仓储服务要点</h2>
      <p class="text-xs text-gray-400 text-center mb-8">女装/男装/内衣/运动服 — 不同品类的存储、质检与包装规范</p>
      <div class="overflow-x-auto rounded-xl border border-gray-200">
        <table class="w-full text-sm text-left">
          <thead>
            <tr class="bg-navy-800 text-white">
              <th class="px-5 py-3.5 font-bold text-xs tracking-wider whitespace-nowrap">品类</th>
              <th class="px-5 py-3.5 font-bold text-xs tracking-wider whitespace-nowrap">存储方式</th>
              <th class="px-5 py-3.5 font-bold text-xs tracking-wider whitespace-nowrap">核心质检点</th>
              <th class="px-5 py-3.5 font-bold text-xs tracking-wider whitespace-nowrap">包装规范</th>
              <th class="px-5 py-3.5 font-bold text-xs tracking-wider whitespace-nowrap">特殊注意</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            {CATEGORY_TABLE.map(({ cat, storage, inspect, packing, note }) => (
              <tr class="hover:bg-orange-50/30 transition-colors">
                <td class="px-5 py-4 font-bold text-navy-800 whitespace-nowrap align-top">{cat}</td>
                <td class="px-5 py-4 text-gray-600 align-top text-xs leading-relaxed">{storage}</td>
                <td class="px-5 py-4 text-gray-600 align-top text-xs leading-relaxed">{inspect}</td>
                <td class="px-5 py-4 text-gray-600 align-top text-xs leading-relaxed">{packing}</td>
                <td class="px-5 py-4 text-gray-500 align-top text-xs leading-relaxed">{note}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>
</ServiceLanding>
