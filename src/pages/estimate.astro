---
export const prerender = true
import Layout from '@/layouts/Layout.astro'
import { BRAND } from '@/lib/brand'

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: BRAND.url },
    { '@type': 'ListItem', position: 2, name: '仓储成本估算', item: `${BRAND.url}/estimate` },
  ],
}

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: '如何估算鞋服仓储成本',
  description: '通过选择品类、日均出库量和SKU规模，快速获得新亦源鞋服仓储费用区间参考',
  step: [
    { '@type': 'HowToStep', position: 1, name: '选择商品品类', text: '选择您的商品品类，如快时尚女装、内衣家居、鞋类箱包等' },
    { '@type': 'HowToStep', position: 2, name: '填写日均出库量', text: '选择您的日均出库件数范围' },
    { '@type': 'HowToStep', position: 3, name: '填写SKU规模', text: '选择您的在库SKU数量范围' },
    { '@type': 'HowToStep', position: 4, name: '获取费用区间', text: '系统自动估算月操作费和库存费区间，并推荐合适的仓储方案' },
  ],
}
---

<Layout
  title="鞋服仓储成本估算 - 免费在线报价参考 | 新亦源供应链"
  description="免费在线估算鞋服仓储成本。输入日均出库量、SKU规模和商品品类，30秒获得新亦源专业仓储的月费区间和推荐方案，无需注册。"
  jsonLd={[breadcrumbSchema, howToSchema]}
>
  <!-- Hero -->
  <section class="py-14 lg:py-20 bg-white border-b border-gray-100">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-brand-orange font-bold text-sm tracking-wider uppercase mb-3">免费在线估算</p>
      <h1 class="text-3xl lg:text-4xl font-black text-navy-800 mb-4 leading-tight">
        仓储成本估算器
      </h1>
      <p class="text-gray-500 text-base leading-relaxed max-w-xl mx-auto">
        输入您的业务规模，30秒获得大致费用区间和推荐方案。<br class="hidden sm:block" />
        数据仅供参考，具体报价联系商务确认。
      </p>
    </div>
  </section>

  <!-- Estimator -->
  <section class="py-14 bg-[#f8fafc]">
    <div class="max-w-2xl mx-auto px-4 sm:px-6">

      <form id="est-form" class="est-card" novalidate>

        <!-- Step 1: 品类 -->
        <fieldset class="est-step">
          <legend class="est-step-label"><span class="est-step-num">1</span> 商品品类</legend>
          <div class="est-options" id="cat-options">
            {[
              { value: 'fashion',   label: '快时尚女装 / 男装',  icon: '👗' },
              { value: 'premium',   label: '高端设计师品牌',     icon: '✨' },
              { value: 'underwear', label: '内衣 / 家居服',       icon: '🧦' },
              { value: 'shoes',     label: '鞋类 / 箱包',        icon: '👟' },
              { value: 'kids',      label: '童装 / 亲子',        icon: '🧒' },
              { value: 'cross',     label: '跨境出海品牌',       icon: '🌏' },
            ].map(({ value, label, icon }) => (
              <label class="est-option" data-value={value}>
                <input type="radio" name="category" value={value} class="sr-only" />
                <span class="est-option-icon">{icon}</span>
                <span class="est-option-label">{label}</span>
              </label>
            ))}
          </div>
        </fieldset>

        <!-- Step 2: 日均出库量 -->
        <fieldset class="est-step">
          <legend class="est-step-label"><span class="est-step-num">2</span> 日均出库量（件/日）</legend>
          <div class="est-options" id="vol-options">
            {[
              { value: '500',    label: '500 件以下',      sub: '成长期品牌' },
              { value: '3000',   label: '500 – 3,000',    sub: '中小规模运营' },
              { value: '10000',  label: '3,000 – 1 万',   sub: '多平台全渠道' },
              { value: '50000',  label: '1 万 – 5 万',    sub: '头部品牌日常' },
              { value: '100000', label: '5 万件以上',      sub: '大促 / 集团规模' },
            ].map(({ value, label, sub }) => (
              <label class="est-option est-option--wide" data-value={value}>
                <input type="radio" name="volume" value={value} class="sr-only" />
                <span class="est-option-label">{label}</span>
                <span class="est-option-sub">{sub}</span>
              </label>
            ))}
          </div>
        </fieldset>

        <!-- Step 3: SKU 规模 -->
        <fieldset class="est-step">
          <legend class="est-step-label"><span class="est-step-num">3</span> 在库 SKU 数量</legend>
          <div class="est-options" id="sku-options">
            {[
              { value: '500',   label: '500 SKU 以下' },
              { value: '3000',  label: '500 – 3,000 SKU' },
              { value: '10000', label: '3,000 – 1 万 SKU' },
              { value: '50000', label: '1 万 SKU 以上' },
            ].map(({ value, label }) => (
              <label class="est-option est-option--wide" data-value={value}>
                <input type="radio" name="sku" value={value} class="sr-only" />
                <span class="est-option-label">{label}</span>
              </label>
            ))}
          </div>
        </fieldset>

        <button type="submit" id="est-btn" class="est-submit" disabled>
          计算费用区间
        </button>
      </form>

      <!-- Result Panel -->
      <div id="est-result" class="est-result hidden" aria-live="polite">
        <div class="est-result-header">
          <p class="est-result-eyebrow">参考估算结果</p>
          <h2 id="est-range" class="est-result-range">—</h2>
          <p class="est-result-unit">万元 / 月（含基础操作费 + 仓储费，不含运费）</p>
        </div>

        <div id="est-details" class="est-result-details"></div>

        <div class="est-result-note">
          <svg class="w-4 h-4 text-amber-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
          <p>以上为参考区间，实际报价需结合增值服务（RFID、修复、达播支持）、入仓量、合作年限等综合评估。</p>
        </div>

        <div class="est-result-actions">
          <a href="/contact" class="est-cta-primary">获取精准报价</a>
          <button id="est-reset" class="est-cta-secondary">重新估算</button>
        </div>
      </div>

    </div>
  </section>

  <!-- FAQ -->
  <section class="py-14 bg-white">
    <div class="max-w-2xl mx-auto px-4 sm:px-6">
      <h2 class="text-xl font-black text-navy-800 mb-6">常见问题</h2>
      <div class="space-y-4">
        {[
          { q: '是否有最低消费门槛？', a: '没有。新亦源不设最低消费，不收WMS/LMS系统使用费，按实际出入库量计费，适合成长期品牌。' },
          { q: '报价包含哪些费用？', a: '基础报价通常包含：入库操作费、上架操作费、日常保管费、出库操作费。RFID贴标、退货质检修复、达播寄样等为增值服务，按需选配。' },
          { q: '大促期间费用如何计算？', a: '大促期间出库量可能数倍于日常，新亦源支持弹性产能，峰值费率与基础费率相同，不额外收取峰值附加费。' },
          { q: '合同周期一般是多久？', a: '通常为1年或以上，长期合作可享受更优惠的费率。对于新客户，也可先进行3-6个月的试运营期。' },
        ].map(({ q, a }) => (
          <details class="est-faq">
            <summary class="est-faq-q">{q}</summary>
            <p class="est-faq-a">{a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
.est-card {
  background: #fff;
  border: 1px solid #E2E8F0;
  border-radius: 1.25rem;
  padding: 2rem;
  box-shadow: 0 2px 16px rgba(10,26,51,0.06);
}
.est-step { border: none; padding: 0; margin-bottom: 2rem; }
.est-step-label {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  font-size: 0.9375rem;
  font-weight: 800;
  color: #0A1A33;
  margin-bottom: 1rem;
}
.est-step-num {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 1.625rem;
  height: 1.625rem;
  border-radius: 50%;
  background: #E85D26;
  color: #fff;
  font-size: 0.75rem;
  font-weight: 900;
  flex-shrink: 0;
}
.est-options {
  display: flex;
  flex-wrap: wrap;
  gap: 0.625rem;
}
.est-option {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.5rem 1rem;
  border: 1.5px solid #E2E8F0;
  border-radius: 0.625rem;
  cursor: pointer;
  transition: all 0.15s;
  background: #F8FAFC;
  user-select: none;
}
.est-option:hover { border-color: #E85D26; background: #FFF7F5; }
.est-option.selected {
  border-color: #E85D26;
  background: #FFF7F5;
  box-shadow: 0 0 0 2px #E85D2620;
}
.est-option--wide {
  flex: 1;
  min-width: calc(50% - 0.3125rem);
  flex-direction: column;
  align-items: flex-start;
  gap: 0.2rem;
  padding: 0.75rem 1rem;
}
.est-option-icon { font-size: 1.25rem; }
.est-option-label { font-size: 0.875rem; font-weight: 700; color: #0A1A33; }
.est-option-sub { font-size: 0.75rem; color: #94A3B8; }
.est-submit {
  width: 100%;
  padding: 0.875rem;
  border-radius: 0.75rem;
  background: #E85D26;
  color: #fff;
  font-size: 1rem;
  font-weight: 800;
  border: none;
  cursor: pointer;
  transition: background 0.2s, opacity 0.2s;
  letter-spacing: 0.02em;
}
.est-submit:disabled { opacity: 0.4; cursor: not-allowed; }
.est-submit:not(:disabled):hover { background: #c94d1e; }

/* Result */
.est-result { margin-top: 1.5rem; }
.hidden { display: none !important; }
.est-result-header {
  background: #0A1A33;
  border-radius: 1.25rem 1.25rem 0 0;
  padding: 2rem;
  text-align: center;
  color: #fff;
}
.est-result-eyebrow {
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #93C5FD;
  margin-bottom: 0.75rem;
}
.est-result-range {
  font-size: clamp(2rem, 6vw, 3.5rem);
  font-weight: 900;
  color: #fff;
  line-height: 1;
  margin-bottom: 0.5rem;
}
.est-result-unit { font-size: 0.8125rem; color: #94A3B8; }
.est-result-details {
  background: #fff;
  border: 1px solid #E2E8F0;
  border-top: none;
  padding: 1.5rem;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}
.est-detail-item { }
.est-detail-label { font-size: 0.75rem; color: #94A3B8; font-weight: 600; margin-bottom: 0.25rem; }
.est-detail-val { font-size: 0.9375rem; font-weight: 800; color: #0A1A33; }
.est-result-note {
  display: flex;
  gap: 0.625rem;
  align-items: flex-start;
  background: #FFFBEB;
  border: 1px solid #FDE68A;
  border-top: none;
  padding: 1rem 1.5rem;
  font-size: 0.8125rem;
  color: #78350F;
  line-height: 1.6;
}
.est-result-actions {
  display: flex;
  gap: 0.75rem;
  padding: 1.25rem 1.5rem;
  background: #fff;
  border: 1px solid #E2E8F0;
  border-top: none;
  border-radius: 0 0 1.25rem 1.25rem;
}
.est-cta-primary {
  flex: 1;
  display: inline-flex;
  justify-content: center;
  padding: 0.875rem;
  background: #E85D26;
  color: #fff;
  font-weight: 800;
  border-radius: 0.625rem;
  text-decoration: none;
  transition: background 0.2s;
  font-size: 0.9375rem;
}
.est-cta-primary:hover { background: #c94d1e; }
.est-cta-secondary {
  padding: 0.875rem 1.25rem;
  border: 1.5px solid #E2E8F0;
  border-radius: 0.625rem;
  font-weight: 700;
  font-size: 0.875rem;
  color: #475569;
  background: #fff;
  cursor: pointer;
  transition: border-color 0.2s;
}
.est-cta-secondary:hover { border-color: #94A3B8; }

/* FAQ */
.est-faq {
  border: 1px solid #E2E8F0;
  border-radius: 0.875rem;
  overflow: hidden;
}
.est-faq-q {
  padding: 1rem 1.25rem;
  font-weight: 700;
  font-size: 0.9375rem;
  color: #0A1A33;
  cursor: pointer;
  list-style: none;
  display: flex;
  justify-content: space-between;
  align-items: center;
  user-select: none;
}
.est-faq-q::-webkit-details-marker { display: none; }
.est-faq-q::after {
  content: '+';
  font-size: 1.125rem;
  font-weight: 400;
  color: #94A3B8;
  flex-shrink: 0;
  transition: transform 0.2s;
}
details[open] .est-faq-q::after { content: '−'; }
.est-faq-a {
  padding: 0 1.25rem 1rem;
  font-size: 0.875rem;
  color: #475569;
  line-height: 1.7;
  border-top: 1px solid #F1F5F9;
  margin: 0;
}
</style>

<script>
  // ── 选项交互 ──────────────────────────────────────────────────
  const form = document.getElementById('est-form') as HTMLFormElement
  const submitBtn = document.getElementById('est-btn') as HTMLButtonElement
  const resultEl = document.getElementById('est-result') as HTMLElement
  const resetBtn = document.getElementById('est-reset') as HTMLButtonElement

  const selections: Record<string, string> = {}

  document.querySelectorAll<HTMLLabelElement>('.est-option').forEach((label) => {
    label.addEventListener('click', () => {
      const input = label.querySelector('input') as HTMLInputElement
      const name = input.name
      // deselect siblings
      document.querySelectorAll<HTMLLabelElement>(`.est-option input[name="${name}"]`).forEach((inp) => {
        inp.closest('.est-option')?.classList.remove('selected')
      })
      label.classList.add('selected')
      input.checked = true
      selections[name] = input.value
      // enable button when all 3 selected
      submitBtn.disabled = !(selections.category && selections.volume && selections.sku)
    })
  })

  // ── 估算逻辑 ──────────────────────────────────────────────────
  const HANDLING: Record<string, [number, number]> = {
    fashion:   [0.80, 1.20],
    premium:   [1.10, 1.60],
    underwear: [0.50, 0.85],
    shoes:     [1.00, 1.50],
    kids:      [0.80, 1.20],
    cross:     [0.90, 1.30],
  }
  const STORAGE: Record<string, [number, number]> = {
    fashion:   [40, 55],
    premium:   [50, 70],
    underwear: [30, 42],
    shoes:     [45, 60],
    kids:      [38, 50],
    cross:     [38, 52],
  }
  const CAT_LABELS: Record<string, string> = {
    fashion: '快时尚服装', premium: '高端设计师品牌',
    underwear: '内衣/家居服', shoes: '鞋类/箱包',
    kids: '童装/亲子', cross: '跨境出海品牌',
  }

  function calcRange() {
    const cat = selections.category
    const vol = parseInt(selections.volume)
    const sku = parseInt(selections.sku)
    const days = 30

    const [hLo, hHi] = HANDLING[cat]
    const [sLo, sHi] = STORAGE[cat]

    // 操作费：出库量 × 单件费 × 30天
    const opLo = vol * hLo * days / 10000
    const opHi = vol * hHi * days / 10000

    // 库位费：SKU × 单SKU费 / 10000
    const stLo = sku * sLo / 10000
    const stHi = sku * sHi / 10000

    const totalLo = Math.round((opLo + stLo) * 10) / 10
    const totalHi = Math.round((opHi + stHi) * 10) / 10

    const rec = vol >= 10000 ? '全渠道一体化仓储' : vol >= 3000 ? '标准多平台仓配方案' : '成长期灵活仓储'

    return {
      range: `${totalLo.toFixed(1)} – ${totalHi.toFixed(1)}`,
      opLo: opLo.toFixed(1), opHi: opHi.toFixed(1),
      stLo: stLo.toFixed(1), stHi: stHi.toFixed(1),
      catLabel: CAT_LABELS[cat],
      volLabel: vol >= 100000 ? '5万件以上' : vol >= 50000 ? '1万–5万件' : vol >= 10000 ? '3000–1万件' : vol >= 3000 ? '500–3000件' : '500件以下',
      rec,
    }
  }

  form.addEventListener('submit', (e) => {
    e.preventDefault()
    const r = calcRange()

    const rangeEl = document.getElementById('est-range') as HTMLElement
    const detailsEl = document.getElementById('est-details') as HTMLElement

    rangeEl.textContent = r.range
    detailsEl.innerHTML = `
      <div class="est-detail-item"><div class="est-detail-label">品类</div><div class="est-detail-val">${r.catLabel}</div></div>
      <div class="est-detail-item"><div class="est-detail-label">日均出库</div><div class="est-detail-val">${r.volLabel}</div></div>
      <div class="est-detail-item"><div class="est-detail-label">月操作费</div><div class="est-detail-val">${r.opLo} – ${r.opHi} 万</div></div>
      <div class="est-detail-item"><div class="est-detail-label">月库存费</div><div class="est-detail-val">${r.stLo} – ${r.stHi} 万</div></div>
      <div class="est-detail-item" style="grid-column:span 2"><div class="est-detail-label">推荐方案</div><div class="est-detail-val">${r.rec}</div></div>
    `

    form.classList.add('hidden')
    resultEl.classList.remove('hidden')
    resultEl.scrollIntoView({ behavior: 'smooth', block: 'start' })
  })

  resetBtn.addEventListener('click', () => {
    resultEl.classList.add('hidden')
    form.classList.remove('hidden')
    document.querySelectorAll('.est-option').forEach(el => el.classList.remove('selected'))
    document.querySelectorAll<HTMLInputElement>('.est-option input').forEach(inp => inp.checked = false)
    Object.keys(selections).forEach(k => delete selections[k])
    submitBtn.disabled = true
    form.scrollIntoView({ behavior: 'smooth', block: 'start' })
  })
</script>
