---
import ServiceLanding from '@/layouts/ServiceLanding.astro'

const COMPARE_ROWS = [
  { item: '订单规模', b2c: '单笔1–5件，SKU少', b2b: '单笔几十到数千件，多SKU混发' },
  { item: '发货频率', b2c: '高频少量，全天持续波次', b2b: '低频大批，按补货周期或季节集中发' },
  { item: '包装要求', b2c: '快递箱+面单', b2b: '整件/吊装+分货明细单+货架标签' },
  { item: '分货逻辑', b2c: '按订单号一对一拣货', b2b: '按门店/客户分区拣货，分色分码分规格' },
  { item: '物流方式', b2c: '快递（顺丰/圆通等）', b2b: '零担/整车/同城货运 + 快递混合' },
  { item: '系统对接', b2c: '平台奇门接口', b2b: 'ERP/进销存系统 + 自定义分货规则' },
]

const SCENARIO_ITEMS = [
  {
    title: '连锁门店补货',
    desc: '品牌在全国有100+门店，每周/每月按门店发补货，每店分色分码分规格，附分货明细单和货架条码标签。',
    tag: '连锁零售',
    tagColor: 'bg-brand-orange/10 text-brand-orange',
  },
  {
    title: '批发商/加盟商铺货',
    desc: '季节换新时向全国加盟商或批发客户集中铺货，单客户数百到数千件，需按客户分仓分拣，整件打包出库。',
    tag: '批发铺货',
    tagColor: 'bg-navy-100 text-navy-700',
  },
  {
    title: '线下展会/快闪发货',
    desc: '品牌参展或开快闪店，需在指定时间前将样品/展品/销售备货发至指定展馆或临时仓，时间节点严格。',
    tag: '展会备货',
    tagColor: 'bg-green-100 text-green-600',
  },
  {
    title: '电商+门店一盘货',
    desc: '同一库存同时服务线上B2C订单和线下门店补货，库存统一在新亦源仓管理，按需切换B2C/B2B出库模式。',
    tag: 'O2O融合',
    tagColor: 'bg-purple-100 text-purple-600',
  },
]
---

<ServiceLanding
  title="B2B门店仓配服务商 — 连锁门店补货、批发铺货、分货标签一体化 | 新亦源"
  description="新亦源B2B门店仓配，专为连锁品牌、批发商、加盟商提供门店补货配送、分色分码分货、货架标签、分货明细单等B2B仓配服务，支持ERP系统对接，全国门店覆盖。"
  slug="b2b-mendian-cangpei"
  breadcrumbLabel="B2B门店仓配"
  eyebrow="B2B门店仓配 · 连锁补货 + 批发铺货专业服务"
  h1="B2B门店仓配"
  h1sub="连锁门店补货、批发铺货，分色分码精准配货"
  heroDesc="新亦源B2B门店仓配专为鞋服连锁品牌、批发商和加盟体系设计，提供门店补货配送、按门店分货分拣、货架标签制作、ERP系统对接等全流程B2B仓配服务，服务合作品牌遍布全国的门店网络。"
  imgSrc="/w-hanging3.webp"
  imgAlt="B2B门店仓配 — 连锁门店批量补货配送"
  stats={[
    { stat: '140+', label: '合作品牌', sub: '含多家连锁零售品牌' },
    { stat: '6000+', label: '服务区域', sub: '覆盖全国主要城市及区县' },
    { stat: '分色分码', label: '精准分货', sub: '按门店SKU规格独立分拣' },
    { stat: '0元', label: 'ERP对接费用', sub: '支持主流进销存系统' },
  ]}
  contentDesc="B2B门店仓配与B2C电商仓配在操作逻辑上有根本差异：B2B以门店为单位分货，需要按门店的SKU、颜色、码数、数量精准分拣，附上分货明细单和货架条码标签；物流方式以零担、整车为主，配合同城快运和快递混合发货；系统上需要与品牌方ERP/进销存对接，自动接收补货指令并执行出库。新亦源B2B仓配团队已服务多个连锁鞋服品牌，积累了完善的门店分货流程和系统对接经验，支持按季节集中铺货、按需补货、紧急调货等多种B2B发货模式。"
  featuresLabel="B2B仓配核心能力"
  features={[
    { title: '门店分货精准分拣', desc: '按门店编号独立分区拣货，分色分码分规格，每箱附分货明细单（门店名称、SKU清单、数量），减少门店收货时的清点差错。' },
    { title: '货架标签 / 吊牌加工', desc: '根据门店或客户要求制作货架价格标签、商品条码、吊牌，支持不同门店使用不同标签格式，出库前完成贴标，门店收货即可上架。' },
    { title: 'ERP / 进销存系统对接', desc: '与品牌方ERP、进销存或门店管理系统免费打通，自动接收补货指令、生成出库单，发货后自动回传物流单号，无需人工二次录入。' },
    { title: '零担 / 整车 / 快递混合发货', desc: '根据门店距离和货量灵活选择物流方式：近郊门店同城货运当日送达，跨省门店零担次日到两日，单件轻货走快递，降低综合物流成本。' },
    { title: 'B2C+B2B一盘货管理', desc: '同一批库存同时支持线上B2C发货和线下门店B2B补货，库存统一管理，系统自动按订单类型选择出库模式，无需分仓备货。' },
    { title: '季节集中铺货保障', desc: '春夏/秋冬换季时集中铺货，提前预排班，保障在约定时间内完成全国门店补货，历史大规模铺货（千家门店级别）零违约记录。' },
  ]}
  faqs={[
    {
      q: '新亦源B2B仓配和B2C仓配有什么区别？',
      a: 'B2B门店仓配的核心差异在三点：①分货逻辑不同，B2B按门店独立分区拣货，每个门店有独立明细单；②物流方式不同，B2B主要用零担/整车，成本更低；③系统对接不同，B2B需要与ERP/进销存系统打通，自动处理补货指令。新亦源同时支持B2C和B2B两种发货模式，一套库存可同时服务两种渠道。',
    },
    {
      q: '门店数量较多（50家以上），新亦源能处理吗？',
      a: '完全可以。新亦源已服务多个拥有100家以上门店的连锁品牌，建立了完善的门店分货作业标准：门店档案维护→分货规则配置→批量分拣→逐店打包→物流发运→回传单号，全流程标准化。门店越多越有规模优势，欢迎联系商务团队评估方案。',
    },
    {
      q: '新亦源支持与哪些ERP系统对接？',
      a: '支持主流进销存和ERP系统，包括：用友、金蝶、SAP、管家婆、旺店通、聚水潭、飞书多维表格等。也支持品牌方自研系统通过API接口对接。对接费用免费，通常1-2周完成联调上线。',
    },
    {
      q: '季节换新集中铺货时，能在多少天内完成全国发货？',
      a: '取决于门店数量和SKU规模。通常情况下：100家门店以内，3-5天完成全国铺货；500家门店，7-10天；1000家以上，提前规划预排班，通常14天内完成。建议品牌提前1-2个月告知铺货计划，我们提前备仓和排班，确保时效。',
    },
    {
      q: 'B2B发货的货架标签和分货明细单怎么定制？',
      a: '支持完全按品牌要求定制：①货架标签：可包含门店名称、SKU编码、颜色、尺码、价格、条码等；②分货明细单：按门店生成，包含本次补货所有商品明细；③包装箱标：箱号、目的门店、商品汇总。首次合作时，商务团队会收集您的标签格式要求，录入系统模板，后续自动批量生成。',
    },
  ]}
>
  <section slot="unique" class="py-14 bg-white border-b border-gray-100" aria-labelledby="b2b-compare-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="b2b-compare-heading" class="text-xl font-black text-navy-800 mb-1 text-center">B2B门店仓配 vs B2C电商仓配 — 核心差异</h2>
      <p class="text-xs text-gray-400 text-center mb-8">两种模式作业逻辑不同，新亦源同时支持，一盘货统一管理</p>

      <div class="overflow-x-auto rounded-xl border border-gray-200 mb-10">
        <table class="w-full text-sm text-left">
          <thead>
            <tr class="bg-navy-800 text-white">
              <th class="px-5 py-3.5 font-bold text-xs tracking-wider w-28">对比项</th>
              <th class="px-5 py-3.5 font-bold text-xs tracking-wider">
                <span class="inline-block px-2 py-0.5 rounded bg-white/20 mr-1 text-[10px]">B2C</span>电商发货
              </th>
              <th class="px-5 py-3.5 font-bold text-xs tracking-wider">
                <span class="inline-block px-2 py-0.5 rounded bg-brand-orange/20 text-brand-orange mr-1 text-[10px]">B2B</span>门店补货
              </th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            {COMPARE_ROWS.map(({ item, b2c, b2b }) => (
              <tr class="hover:bg-orange-50/20 transition-colors">
                <td class="px-5 py-4 font-bold text-navy-700 text-xs align-top whitespace-nowrap">{item}</td>
                <td class="px-5 py-4 text-gray-500 text-xs leading-relaxed align-top">{b2c}</td>
                <td class="px-5 py-4 text-gray-600 text-xs leading-relaxed align-top font-medium">{b2b}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h3 class="text-sm font-bold text-navy-800 mb-4">典型B2B仓配使用场景</h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {SCENARIO_ITEMS.map(({ title, desc, tag, tagColor }) => (
          <div class="bg-gray-50 rounded-xl border border-gray-200 p-4 flex flex-col gap-3">
            <span class={`inline-block text-[10px] font-black px-2 py-0.5 rounded-full w-fit ${tagColor}`}>{tag}</span>
            <h4 class="font-black text-navy-800 text-sm">{title}</h4>
            <p class="text-xs text-gray-500 leading-snug">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</ServiceLanding>
