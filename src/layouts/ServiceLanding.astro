---
import Layout from '@/layouts/Layout.astro'
import { BRAND } from '@/lib/brand'

interface StatItem { stat: string; label: string; sub: string }
interface FeatureItem { title: string; desc: string }
interface FaqItem { q: string; a: string }

interface Props {
  title: string
  description: string
  slug: string
  breadcrumbLabel: string
  eyebrow: string
  h1: string
  h1sub: string
  heroDesc: string
  imgSrc: string
  imgAlt: string
  stats: [StatItem, StatItem, StatItem, StatItem]
  contentDesc: string
  featuresLabel: string
  features: FeatureItem[]
  faqs: FaqItem[]
}

const {
  title, description, slug, breadcrumbLabel,
  eyebrow, h1, h1sub, heroDesc, imgSrc, imgAlt,
  stats, contentDesc, featuresLabel, features, faqs,
} = Astro.props

const pageUrl = `${BRAND.url}/${slug}`

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: BRAND.url },
    { '@type': 'ListItem', position: 2, name: '产品服务', item: `${BRAND.url}/product` },
    { '@type': 'ListItem', position: 3, name: breadcrumbLabel, item: pageUrl },
  ],
}

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${pageUrl}#service`,
  name: h1,
  description,
  provider: {
    '@type': 'Organization',
    '@id': `${BRAND.url}/#organization`,
    name: BRAND.fullName,
  },
  areaServed: { '@type': 'Country', name: '中国' },
  url: pageUrl,
}

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: { '@type': 'Answer', text: a },
  })),
}
---

<Layout
  title={title}
  description={description}
  canonical={pageUrl}
  jsonLd={[breadcrumbSchema, serviceSchema, faqSchema]}
>
  <!-- Hero -->
  <section class="relative py-16 lg:py-28 overflow-hidden" aria-labelledby="lp-h1">
    <img
      src={imgSrc}
      alt={imgAlt}
      class="absolute inset-0 w-full h-full object-cover"
      fetchpriority="high"
    />
    <div
      class="absolute inset-0"
      style="background:linear-gradient(105deg,rgba(8,20,42,.95) 0%,rgba(8,20,42,.80) 40%,rgba(8,20,42,.50) 70%,rgba(8,20,42,.25) 100%);"
      aria-hidden="true"
    ></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-brand-orange font-semibold text-sm tracking-wider uppercase mb-3">{eyebrow}</p>
      <h1 id="lp-h1" class="text-4xl lg:text-5xl font-black text-white leading-tight mb-2">{h1}</h1>
      <p class="text-brand-orange font-bold text-lg mb-4">{h1sub}</p>
      <p class="text-lg text-navy-100 max-w-2xl leading-relaxed mb-8">{heroDesc}</p>
      <div class="flex flex-wrap gap-3">
        <a href="/contact" class="inline-flex items-center px-6 py-3 bg-brand-orange hover:bg-brand-orange-dark text-white font-bold rounded-xl transition-colors text-sm">
          免费获取方案
        </a>
        <a href="/product" class="inline-flex items-center px-6 py-3 border border-white/30 hover:border-white/60 text-white/80 hover:text-white font-medium rounded-xl transition-colors text-sm">
          查看全部产品
        </a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <div class="bg-navy-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 divide-x divide-navy-700 divide-y lg:divide-y-0">
        {stats.map(({ stat, label, sub }) => (
          <div class="px-6 py-5 text-center">
            <p class="text-2xl font-black text-brand-orange">{stat}</p>
            <p class="text-sm font-semibold text-white mt-0.5">{label}</p>
            <p class="text-xs text-navy-300 mt-0.5">{sub}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Unique module slot (each page injects its own differentiating section here) -->
  <slot name="unique" />

  <!-- Main content -->
  <section class="py-16 lg:py-24 bg-white" aria-labelledby="lp-detail-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="lg:grid lg:grid-cols-2 lg:gap-20 items-start">

        <!-- Left: description -->
        <div>
          <h2 id="lp-detail-heading" class="text-2xl lg:text-3xl font-black text-navy-800 mb-6">{h1} — 服务详情</h2>
          <p class="text-gray-600 leading-relaxed mb-8">{contentDesc}</p>
          <div class="p-4 bg-gray-50 rounded-xl border border-gray-100">
            <p class="text-xs text-gray-400 mb-2">相关页面</p>
            <div class="flex flex-wrap gap-4">
              <a href="/product" class="text-sm text-brand-orange hover:underline font-medium">产品服务总览</a>
              <a href="/cases" class="text-sm text-gray-500 hover:text-navy-700">合作案例</a>
              <a href="/contact" class="text-sm text-gray-500 hover:text-navy-700">联系商务</a>
            </div>
          </div>
        </div>

        <!-- Right: features list -->
        <div>
          <p class="text-[11px] font-bold text-gray-400 tracking-[0.25em] uppercase mb-4">{featuresLabel}</p>
          <div class="divide-y divide-gray-100">
            {features.map(({ title, desc }) => (
              <div class="py-4 flex gap-4 group hover:bg-orange-50/40 -mx-3 px-3 transition-colors">
                <div class="w-1 flex-shrink-0 rounded-full bg-brand-orange/30 group-hover:bg-brand-orange transition-colors self-stretch"></div>
                <div>
                  <h3 class="text-sm font-bold text-navy-800 mb-1">{title}</h3>
                  <p class="text-sm text-gray-500 leading-relaxed">{desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 bg-gray-50" aria-labelledby="lp-faq-heading">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="lp-faq-heading" class="text-2xl font-black text-navy-800 mb-10 text-center">{h1} 常见问题</h2>
      <dl class="space-y-4">
        {faqs.map(({ q, a }) => (
          <div class="bg-white rounded-xl border border-gray-100 p-6">
            <dt class="font-bold text-navy-800 mb-3 flex gap-3">
              <span class="text-brand-orange flex-shrink-0 font-black">Q</span>
              {q}
            </dt>
            <dd class="text-gray-600 text-sm leading-relaxed ml-6">{a}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-14 bg-navy-50" aria-labelledby="lp-cta-heading">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 id="lp-cta-heading" class="text-2xl lg:text-3xl font-black text-navy-800 mb-4">
        想了解{h1}具体方案？
      </h2>
      <p class="text-gray-600 mb-8">告诉我们您的品类、规模和当前痛点，新亦源为您定制最优方案</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/contact" class="inline-flex items-center px-7 py-3.5 bg-brand-orange hover:bg-brand-orange-dark text-white font-bold rounded-xl transition-colors">
          免费获取方案
        </a>
        <a href="/cases" class="inline-flex items-center px-7 py-3.5 border border-navy-300 hover:border-navy-500 text-navy-700 font-semibold rounded-xl transition-colors">
          查看合作案例
        </a>
      </div>
    </div>
  </section>
</Layout>
